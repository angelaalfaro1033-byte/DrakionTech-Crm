@using DrakionTech.Crm.Business.DTOs.Empleado
@using DrakionTech.Crm.Business.DTOs.RolUsuario
@using DrakionTech.Crm.Business.DTOs.Especialidad
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Data.Entities.Enums
@using DrakionTech.Crm.Business.Common
@inject IRolUsuarioService RolService
@inject IEspecialidadService EspecialidadService

<EditForm Model="@Model" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="validation-summary" />
    <div class="row g-3">

        <div class="col-md-6">
            <label class="form-label">Tipo de documento</label>
            <InputSelect @bind-Value="Model.TipoDocumento" class="form-select">
                <option value="">-- Selecciona --</option>
                <option value="@TipoDocumento.CC">Cédula de ciudadanía</option>
                <option value="@TipoDocumento.NIT">NIT</option>
                <option value="@TipoDocumento.CE">Cédula de extranjería</option>
                <option value="@TipoDocumento.PA">Pasaporte</option>
                <option value="@TipoDocumento.RC">Registro civil</option>
                <option value="@TipoDocumento.TI">Tarjeta de identidad</option>
            </InputSelect>
            <ValidationMessage For="@(() => Model.TipoDocumento)" class="validation-message" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Número de documento</label>
            <InputText @bind-Value="Model.NumeroDocumento"
                       class="form-control"
                       placeholder="Solo números"
                       inputmode="numeric" />
            <ValidationMessage For="@(() => Model.NumeroDocumento)" class="validation-message" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Nombre</label>
            <InputText @bind-Value="Model.Nombre" class="form-control" />
            <ValidationMessage For="@(() => Model.Nombre)" class="validation-message" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Apellido</label>
            <InputText @bind-Value="Model.Apellido" class="form-control" />
            <ValidationMessage For="@(() => Model.Apellido)" class="validation-message" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Correo electrónico</label>
            <InputText @bind-Value="Model.Email" class="form-control" />
            <ValidationMessage For="@(() => Model.Email)" class="validation-message" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Rol</label>
            <CreatableSelect TItem="RolUsuarioDto"
                             Items="roles"
                             ObtenerTexto="r => r.Nombre"
                             ObtenerId="r => r.Id"
                             Placeholder="Buscar o crear rol..."
                             ValorSeleccionadoTexto="@Model.Rol"
                             OnSeleccionar="OnRolSeleccionado"
                             OnCrear="OnRolCreado" />
            <ValidationMessage For="@(() => Model.Rol)" class="validation-message" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Especialidad</label>
            <CreatableSelect TItem="EspecialidadDto"
                             Items="especialidadesFiltradas"
                             ObtenerTexto="e => e.Nombre"
                             ObtenerId="e => e.Id"
                             Placeholder="@(Model.RolUsuarioId is null ? "Selecciona un rol primero" : "Buscar o crear especialidad...")"
                             ValorSeleccionadoTexto="@Model.Cargo"
                             OnSeleccionar="OnEspecialidadSeleccionada"
                             OnCrear="OnEspecialidadCreada" />
            <ValidationMessage For="@(() => Model.Cargo)" class="validation-message" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Salario</label>
            <InputNumber @bind-Value="Model.Salario" class="form-control" placeholder="0.00" />
            <ValidationMessage For="@(() => Model.Salario)" class="validation-message" />
        </div>

    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">@TextoBoton</button>
        @if (OnCancel.HasDelegate)
        {
            <button type="button" class="btn btn-secondary" @onclick="OnCancel">Cancelar</button>
        }
    </div>

</EditForm>

@code {
    [Parameter] public CrearEmpleadoDto Model { get; set; } = new();
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string TextoBoton { get; set; } = "Guardar";

    private List<RolUsuarioDto> roles = [];
    private List<EspecialidadDto> todasEspecialidades = [];
    private List<EspecialidadDto> especialidadesFiltradas = [];

    protected override async Task OnInitializedAsync()
    {
        roles = await RolService.ObtenerTodosAsync();
        todasEspecialidades = await EspecialidadService.ObtenerTodosAsync();

        if (!string.IsNullOrEmpty(Model.Rol) && Model.RolUsuarioId is null)
        {
            var rol = roles.FirstOrDefault(r => r.Nombre == Model.Rol);
            if (rol is not null)
            {
                Model.RolUsuarioId = rol.Id;
                FiltrarEspecialidades(rol.Id);
                if (!string.IsNullOrEmpty(Model.Cargo) && Model.EspecialidadId is null)
                {
                    var esp = especialidadesFiltradas.FirstOrDefault(e => e.Nombre == Model.Cargo);
                    if (esp is not null) Model.EspecialidadId = esp.Id;
                }
            }
        }
        else if (Model.RolUsuarioId is not null)
        {
            FiltrarEspecialidades(Model.RolUsuarioId.Value);
        }
    }

    private async Task OnRolSeleccionado(RolUsuarioDto? rol)
    {
        if (rol is null)
        {
            Model.RolUsuarioId = null;
            Model.Rol = string.Empty;
            especialidadesFiltradas = [];
        }
        else
        {
            Model.RolUsuarioId = rol.Id;
            Model.Rol = rol.Nombre;
            FiltrarEspecialidades(rol.Id);
        }
        Model.EspecialidadId = null;
        Model.Cargo = string.Empty;
    }

    private async Task OnRolCreado(string nombre)
    {
        var nuevo = await RolService.CrearYObtenerAsync(nombre);
        if (!roles.Any(r => r.Id == nuevo.Id))
            roles.Add(nuevo);

        Model.RolUsuarioId = nuevo.Id;
        Model.Rol = nuevo.Nombre;
        FiltrarEspecialidades(nuevo.Id);
        Model.EspecialidadId = null;
        Model.Cargo = string.Empty;
    }

    private async Task OnEspecialidadSeleccionada(EspecialidadDto? esp)
    {
        if (esp is null)
        {
            Model.EspecialidadId = null;
            Model.Cargo = string.Empty;
        }
        else
        {
            Model.EspecialidadId = esp.Id;
            Model.Cargo = esp.Nombre;
        }
    }

    private async Task OnEspecialidadCreada(string nombre)
    {
        if (Model.RolUsuarioId is null) return;

        var nueva = await EspecialidadService.CrearYObtenerAsync(nombre, Model.RolUsuarioId.Value);
        if (!todasEspecialidades.Any(e => e.Id == nueva.Id))
            todasEspecialidades.Add(nueva);

        FiltrarEspecialidades(Model.RolUsuarioId.Value);
        Model.EspecialidadId = nueva.Id;
        Model.Cargo = nueva.Nombre;
    }

    private void FiltrarEspecialidades(int rolId)
    {
        especialidadesFiltradas = todasEspecialidades
            .Where(e => e.RolUsuarioId == rolId && e.Activo)
            .ToList();
    }
}