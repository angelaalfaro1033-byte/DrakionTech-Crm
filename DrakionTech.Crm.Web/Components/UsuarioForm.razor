@using DrakionTech.Crm.Business.DTOs.Usuario
@using DrakionTech.Crm.Business.DTOs.RolUsuario

<EditForm Model="@Model" OnValidSubmit="OnValidSubmit" class="form-container">
    <DataAnnotationsValidator />
    <ValidationSummary class="validation-summary" />
    <div class="form-card">
        <h3 class="form-title">Información del Usuario</h3>
        <div class="form-grid">
            <div class="form-field">
                <label>Nombre</label>
                <InputText @bind-Value="Model.Nombre" class="input-control" />
            </div>
            <div class="form-field">
                <label>Apellido</label>
                <InputText @bind-Value="Model.Apellido" class="input-control" />
            </div>
            <div class="form-field">
                <label>Correo</label>
                <InputText @bind-Value="Model.Email" class="input-control" />
            </div>
            <div class="form-field">
                <label>Teléfono</label>
                <InputText @bind-Value="Model.Telefono" class="input-control" />
            </div>
            <div class="form-field full-width">
                <label>Rol</label>
                <InputSelect @bind-Value="Model.RolId" class="input-control">
                    <option value="0">-- Selecciona un rol --</option>
                    @foreach (var rol in Roles)
                    {
                        <option value="@rol.Id">@rol.Nombre</option>
                    }
                </InputSelect>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn primary">@TextoBoton</button>
            @if (OnCancel.HasDelegate)
            {
                <button type="button" class="btn secondary" @onclick="OnCancel">
                    Cancelar
                </button>
            }
        </div>
    </div>
</EditForm>

@code {
    [Parameter] public CrearUsuarioDto Model { get; set; } = new();
    [Parameter] public List<RolUsuarioDto> Roles { get; set; } = new();
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string TextoBoton { get; set; } = "Guardar";
}