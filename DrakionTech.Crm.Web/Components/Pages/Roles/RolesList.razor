@page "/roles"

@using DrakionTech.Crm.Business.DTOs.RolUsuario
@using DrakionTech.Crm.Business.Interfaces

@inject IRolUsuarioService RolUsuarioService

<div class="roles-container">

    <!-- HEADER -->
    <div class="empresas-header">
        <div>
            <h1 class="empresas-title">Roles</h1>
            <p class="empresas-subtitle">Gestiona los roles del sistema</p>
        </div>
        <a class="btn btn-primary" href="/roles/crear">
            + Nuevo Rol
        </a>
    </div>

    @if (roles is null)
    {
        <p>Cargando roles...</p>
    }
    else if (!roles.Any())
    {
        <div class="alert alert-info">
            No hay roles registrados.
        </div>
    }
    else
    {
        <div class="ui-toolbar">
            <div class="ui-search">
                <i class="bi bi-search"></i>
                <input class="form-control"
                       placeholder="Buscar por nombre..."
                       @bind="busqueda"
                       @bind:event="oninput" />
            </div>

            <select class="form-select" @bind="estadoSeleccionado">
                <option value="">Todos</option>
                <option value="true">Activos</option>
                <option value="false">Inactivos</option>
            </select>
        </div>

        <div class="ui-card">
            <table class="ui-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in rolesFiltrados!)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="ui-actions">
                                    <a href="/roles/editar/@item.Id" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (item.Activo)
                                    {
                                        <button class="btn btn-sm btn-success" @onclick="() => Desactivar(item.Id)" title="Desactivar">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary" @onclick="() => Activar(item.Id)" title="Activar">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private List<RolUsuarioDto>? roles;
    private IEnumerable<RolUsuarioDto>? rolesFiltrados;

    private string? _busqueda;
    private string? _estadoSeleccionado;

    private string? busqueda
    {
        get => _busqueda;
        set { _busqueda = value; AplicarFiltros(); }
    }

    private string? estadoSeleccionado
    {
        get => _estadoSeleccionado;
        set { _estadoSeleccionado = value; AplicarFiltros(); }
    }

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        roles = await RolUsuarioService.ObtenerTodosAsync();
        AplicarFiltros();
    }

    private void AplicarFiltros()
    {
        if (roles is null) return;

        var query = roles.AsQueryable();

        if (!string.IsNullOrWhiteSpace(busqueda))
        {
            var texto = busqueda.Trim().ToLower();
            query = query.Where(r => r.Nombre != null && r.Nombre.ToLower().Contains(texto));
        }

        if (!string.IsNullOrWhiteSpace(estadoSeleccionado))
        {
            var activo = bool.Parse(estadoSeleccionado);
            query = query.Where(r => r.Activo == activo);
        }

        rolesFiltrados = query.ToList();
    }

    private async Task Desactivar(int id)
    {
        await RolUsuarioService.DesactivarAsync(id);
        await Cargar();
    }

    private async Task Activar(int id)
    {
        await RolUsuarioService.ActivarAsync(id);
        await Cargar();
    }
}