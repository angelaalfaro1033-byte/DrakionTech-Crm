@page "/roles"

@using DrakionTech.Crm.Business.DTOs.RolUsuario
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Web.Components
@using DrakionTech.Crm.Web.Shared
@inherits PaginacionBase

@inject IRolUsuarioService RolUsuarioService

<div class="roles-container">

    <div class="page-header">
        <div>
            <h1 class="page-title">Roles</h1>
            <p class="page-subtitle">Gestiona los roles del sistema</p>
        </div>
        <a class="btn btn-primary" href="/roles/crear">
            + Nuevo Rol
        </a>
    </div>

    <FiltroTabla TItem="RolUsuarioDto"
                 PlaceholderBusqueda="Buscar por nombre..."
                 MostrarFiltroEstado="true"
                 OnFiltroChanged="OnFiltroChanged" />

    @if (cargando)
    {
        <p>Cargando roles...</p>
    }
    else if (!roles.Any())
    {
        <div class="alert alert-info">
            No hay roles registrados.
        </div>
    }
    else
    {
        <div class="ui-card">
            <table class="ui-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in roles)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="ui-actions">
                                    <a href="/roles/editar/@item.Id" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (item.Activo)
                                    {
                                        <button class="btn btn-sm btn-success"
                                                @onclick="() => Desactivar(item.Id)"
                                                title="Desactivar">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="() => Activar(item.Id)"
                                                title="Activar">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Paginacion PaginaActual="paginaActual"
                        TotalPaginas="totalPaginas"
                        OnPaginaChanged="IrAPagina" />
        </div>
    }

</div>

@code {
    private List<RolUsuarioDto> roles = new();
    private bool cargando = true;
    private string? busqueda;
    private bool? soloActivos;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        cargando = true;
        StateHasChanged();

        var resultado = await RolUsuarioService.ObtenerTodosConPaginacionAsync(
            busqueda,
            soloActivos,
            paginaActual,
            tamañoPagina);

        roles = resultado.Items;

        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;

        cargando = false;
    }

    private async Task OnFiltroChanged(Dictionary<string, string?> valores)
    {
        busqueda = valores.GetValueOrDefault("busqueda");

        var estado = valores.GetValueOrDefault("estado");

        soloActivos = string.IsNullOrWhiteSpace(estado)
            ? null
            : bool.Parse(estado);

        paginaActual = 1;

        await Cargar();
    }

    private async Task Desactivar(int id) => await CambiarEstado(id, RolUsuarioService.DesactivarAsync);
    private async Task Activar(int id)    => await CambiarEstado(id, RolUsuarioService.ActivarAsync);

    private async Task CambiarEstado(int id, Func<int, Task> accion)
    {
        await accion(id);
        await Cargar();
    }

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(pagina, Cargar);
    }
}