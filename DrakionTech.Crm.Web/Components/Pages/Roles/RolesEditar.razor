@page "/roles/editar/{id:int}"
@attribute [Authorize]
@using DrakionTech.Crm.Business.DTOs.RolUsuario
@using DrakionTech.Crm.Business.Interfaces

@inject IRolUsuarioService RolUsuarioService
@inject NavigationManager Nav

<div class="roles-container">
    <div class="form-card">
        <div class="form-header">
            <h1>Editar rol</h1>
            <p>Actualiza la información</p>
        </div>

        @if (cargando)
        {
            <p>Cargando información...</p>
        }
        else if (!string.IsNullOrEmpty(error))
        {
            <p class="text-danger">@error</p>
        }
        else
        {
            <EditForm Model="rol" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />

                <div class="form-section">
                    <h3>Información del rol</h3>

                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <InputText class="form-control" @bind-Value="rol.Nombre" placeholder="Nombre del rol" />
                        <ValidationMessage For="@(() => rol.Nombre)" class="validation-message" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Actualizar</button>
                    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public int id { get; set; }

    private RolUsuarioDto rol = new();
    private bool cargando = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            rol = await RolUsuarioService.ObtenerPorIdAsync(id);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task Guardar()
    {
        try
        {
            await RolUsuarioService.EditarAsync(rol);
            Nav.NavigateTo("/roles");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void Cancelar()
    {
        Nav.NavigateTo("/roles");
    }
}