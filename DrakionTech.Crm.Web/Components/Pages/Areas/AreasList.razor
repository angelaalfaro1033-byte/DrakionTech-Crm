@page "/areas"
@using DrakionTech.Crm.Business.DTOs.Area
@using DrakionTech.Crm.Web.Components
@inject IAreaService AreaService
@inject NavigationManager Nav
@using DrakionTech.Crm.Web.Shared
@inherits PaginacionBase

<PageTitle>Áreas – DrakionTech CRM</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="mb-0">Áreas organizacionales</h2>
    </div>
    <a href="/areas/nueva" class="btn btn-primary d-flex align-items-center gap-2">
        <i class="bi bi-plus-lg"></i> Nueva área
    </a>
</div>

<FiltroTabla TItem="AreaListDto"
             PlaceholderBusqueda="Buscar por nombre, descripción o responsable…"
             MostrarFiltroEstado="true"
             OnFiltroChanged="OnFiltroChanged" />

<div class="ui-card">

    @if (cargando)
    {
        <div class="text-center py-5 text-muted">
            <div class="spinner-border spinner-border-sm me-2"></div>
            Cargando áreas…
        </div>
    }
    else if (!areas.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-diagram-3 fs-2 d-block mb-2"></i>
            No se encontraron áreas con los filtros aplicados.
        </div>
    }
    else
    {
        <table class="ui-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Responsable</th>
                    <th>Estado</th>
                    <th>Creada</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in areas)
                {
                    <tr>
                        <td>
                            <span style="font-weight:500;color:var(--text-main)">
                                @a.Nombre
                            </span>
                        </td>
                        <td style="color:var(--text-muted);font-size:13px;max-width:220px">
                            @(string.IsNullOrEmpty(a.Descripcion) ? "—" : a.Descripcion)
                        </td>
                        <td style="font-size:13px">
                            @if (string.IsNullOrEmpty(a.ResponsableNombre))
                            {
                                <span class="text-muted">Sin asignar</span>
                            }
                            else
                            {
                                <span>@a.ResponsableNombre</span>
                            }
                        </td>
                        <td>
                            @if (a.Activa)
                            {
                                <span class="badge badge-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactiva</span>
                            }
                        </td>
                        <td style="font-size:13px;color:var(--text-muted)">
                            @a.FechaCreacion.ToString("dd/MM/yyyy")
                        </td>
                        <td>
                            <div class="ui-actions">
                                <a href="/areas/editar/@a.Id" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (a.Activa)
                                {
                                    <button type="button"
                                            class="action-danger border-0 bg-transparent"
                                            title="Desactivar"
                                            @onclick="() => CambiarEstado(a)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="action-success border-0 bg-transparent"
                                            title="Activar"
                                            @onclick="() => CambiarEstado(a)">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <Paginacion PaginaActual="paginaActual"
                    TotalPaginas="totalPaginas"
                    OnPaginaChanged="IrAPagina" />
    }

</div>

@code {
    private List<AreaListDto> areas = new();
    private bool cargando = true;
    private string? busqueda;
    private bool? soloActivas;
    private string? errorAccion;

    protected override async Task OnInitializedAsync() => await CargarAsync();

    private async Task CargarAsync()
    {
        cargando = true;
        StateHasChanged();
        var resultado = await AreaService.ObtenerTodasConPaginacionAsync(
            busqueda,
            soloActivas,
            paginaActual,
            tamañoPagina);

        areas = resultado.Items;

        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;

        cargando = false;
    }

    private async Task OnFiltroChanged(Dictionary<string, string?> valores)
    {
        busqueda = valores.GetValueOrDefault("busqueda");
        var estado = valores.GetValueOrDefault("estado");
        soloActivas = string.IsNullOrWhiteSpace(estado) ? null : bool.Parse(estado);
        paginaActual = 1;
        await CargarAsync();
    }

    private async Task CambiarEstado(AreaListDto area)
    {
        try
        {
            await AreaService.CambiarEstadoAsync(area.Id, !area.Activa);
            await CargarAsync();
        }
        catch (InvalidOperationException ex)
        {
            errorAccion = ex.Message;
        }
    }

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(pagina, CargarAsync);
    }
}