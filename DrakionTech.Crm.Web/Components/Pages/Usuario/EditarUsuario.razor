@page "/usuarios/editar/{id:int}"
@attribute [Authorize]
@using DrakionTech.Crm.Business.DTOs.Usuario
@using DrakionTech.Crm.Business.DTOs.RolUsuario
@using DrakionTech.Crm.Business.Interfaces
@inject IUsuarioService UsuarioService
@inject IRolUsuarioService RolUsuarioService
@inject NavigationManager Nav

<div class="empleados-container">
    <div class="form-card">
        <div class="form-header">
            <h1>Editar usuario</h1>
            <p>Actualiza la información</p>
        </div>

        @if (cargando)
        {
            <p>Cargando información...</p>
        }
        else if (!string.IsNullOrEmpty(error))
        {
            <p class="text-danger">@error</p>
        }
        else
        {
            <UsuarioForm Model="usuarioForm"
                         Roles="roles"
                         OnValidSubmit="Guardar"
                         OnCancel="Cancelar"
                         TextoBoton="Actualizar" />
        }
    </div>
</div>

@code {
    [Parameter] public int id { get; set; }

    private CrearUsuarioDto usuarioForm = new();
    private List<RolUsuarioDto> roles = new();
    private bool cargando = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            roles = await RolUsuarioService.ObtenerTodosAsync();

            var u = await UsuarioService.ObtenerPorIdAsync(id);
            usuarioForm = new CrearUsuarioDto
            {
                Nombre = u.Nombre,
                Apellido = u.Apellido,
                Email = u.Email,
                Telefono = u.Telefono,
                RolId = roles.FirstOrDefault(r => r.Nombre == u.Rol)?.Id ?? 0
            };
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task Guardar()
    {
        try
        {
            var dto = new ActualizarUsuarioDto
            {
                Id = id,
                Nombre = usuarioForm.Nombre,
                Apellido = usuarioForm.Apellido,
                Email = usuarioForm.Email,
                Telefono = usuarioForm.Telefono,
                RolId = usuarioForm.RolId
            };

            await UsuarioService.EditarAsync(dto);
            Nav.NavigateTo("/usuarios");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void Cancelar()
    {
        Nav.NavigateTo("/usuarios");
    }
}