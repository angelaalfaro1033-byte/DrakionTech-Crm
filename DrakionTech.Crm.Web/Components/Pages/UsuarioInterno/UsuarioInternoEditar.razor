@page "/usuarios-internos/{Id:int}"

@inject IUsuarioInternoService UsuarioService
@inject NavigationManager Nav

<h3>Editar Usuario Interno</h3>

@if (model == null)
{
    <p>Cargando...</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label>Nombre</label>
            <InputText class="form-control"
                       @bind-Value="model.Nombre" />
        </div>

        <div class="mb-3">
            <label>Apellido</label>
            <InputText class="form-control"
                       @bind-Value="model.Apellido" />
        </div>

        <div class="mb-3">
            <label>Email</label>
            <InputText class="form-control"
                       @bind-Value="model.Email" />
        </div>

        <div class="mb-3">
            <label>Teléfono</label>
            <InputText class="form-control"
                       @bind-Value="model.Telefono" />
        </div>

        <div class="form-check mb-3">
            <InputCheckbox class="form-check-input"
                           @bind-Value="model.Activo" />
            <label class="form-check-label">Activo</label>
        </div>

        <button class="btn btn-success">Guardar</button>
        <button type="button"
                class="btn btn-secondary ms-2"
                @onclick="Cancelar">
            Cancelar
        </button>
    </EditForm>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private ActualizarUsuarioInternoDto? model;

    protected override async Task OnInitializedAsync()
    {
        var usuario = await UsuarioService.ObtenerPorIdAsync(Id);

        model = new ActualizarUsuarioInternoDto
        {
            Nombre = usuario.Nombre,
            Apellido = usuario.Apellido,
            Email = usuario.Email,
            Telefono = usuario.Telefono,
            Activo = usuario.Activo
        };
    }

    private async Task Guardar()
    {
        await UsuarioService.ActualizarAsync(Id, model!);
        Nav.NavigateTo("/usuarios-internos");
    }

    private void Cancelar()
        => Nav.NavigateTo("/usuarios-internos");
}