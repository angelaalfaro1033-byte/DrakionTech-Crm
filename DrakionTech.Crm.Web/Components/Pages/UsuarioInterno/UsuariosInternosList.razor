@page "/usuarios-internos"
@attribute [Authorize]
@inject IUsuarioInternoService UsuarioService
@inject NavigationManager Nav

<div class="usuarios-container">

    <div class="usuarios-header">
        <div>
            <h1 class="usuarios-title">Usuarios Internos</h1>
            <p class="usuarios-subtitle">Gestiona los usuarios del sistema</p>
        </div>

        <button class="btn btn-primary" @onclick="CrearNuevo">
            + Nuevo Usuario
        </button>
    </div>

    @if (usuarios is null)
    {
        <p>Cargando usuarios...</p>
    }
    else if (!usuarios.Any())
    {
        <div class="alert alert-info">
            No hay usuarios registrados.
        </div>
    }
    else
    {
        <div class="ui-toolbar">

            <div class="ui-search">
                <i class="bi bi-search"></i>
                <input class="form-control"
                       placeholder="Buscar por nombre, email o teléfono..."
                       @bind="busqueda"
                       @bind:event="oninput" />
            </div>

            <select class="form-select" @bind="estadoSeleccionado">
                <option value="">Todos</option>
                <option value="true">Activos</option>
                <option value="false">Inactivos</option>
            </select>

        </div>

        <div class="ui-card">
            <table class="ui-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var u in usuariosFiltrados!)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a href="/usuarios-internos/@u.Id" class="link-empresa">
                                    @($"{u.Nombre} {u.Apellido}")
                                </a>
                            </td>

                            <td>@u.Email</td>
                            <td>@u.Telefono</td>

                            <td>
                                <span class="badge @(u.Activo ? "bg-success" : "bg-secondary")">
                                    @(u.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>

                            <td class="acciones text-end">
                                <div class="ui-actions">

                                    <a href="/usuarios-internos/@u.Id" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {

    private IEnumerable<UsuarioInternoDto>? usuarios;
    private IEnumerable<UsuarioInternoDto>? usuariosFiltrados;

    private string? _busqueda;
    private string? _estadoSeleccionado;

    private string? busqueda
    {
        get => _busqueda;
        set
        {
            _busqueda = value;
            AplicarFiltros();
        }
    }

    private string? estadoSeleccionado
    {
        get => _estadoSeleccionado;
        set
        {
            _estadoSeleccionado = value;
            AplicarFiltros();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        usuarios = await UsuarioService.ObtenerTodosAsync();
        usuariosFiltrados = usuarios;
    }

    private void AplicarFiltros()
    {
        if (usuarios is null) return;

        var query = usuarios.AsQueryable();

        if (!string.IsNullOrWhiteSpace(busqueda))
        {
            var texto = busqueda.ToLower();

            query = query.Where(u =>
                (u.Nombre != null && u.Nombre.ToLower().Contains(texto)) ||
                (u.Apellido != null && u.Apellido.ToLower().Contains(texto)) ||
                (u.Email != null && u.Email.ToLower().Contains(texto)) ||
                (u.Telefono != null && u.Telefono.ToLower().Contains(texto))
            );
        }

        if (!string.IsNullOrWhiteSpace(estadoSeleccionado))
        {
            var activo = bool.Parse(estadoSeleccionado);
            query = query.Where(u => u.Activo == activo);
        }

        usuariosFiltrados = query.ToList();
    }

    private void CrearNuevo()
        => Nav.NavigateTo("/usuarios-internos/nuevo");
}