@page "/"
@attribute [Authorize]
@inject IActividadService ActividadService
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@using DrakionTech.Crm.Web.Extensions

<div class="home-container">
    <div class="home-header">
        <h1>Bienvenido de nuevo</h1>
        <p>¿Qué quieres hacer hoy?</p>
    </div>

    @* Resumen de actividades *@
    <p class="section-title">Mis actividades</p>
    @if (cargando)
    {
        <div class="grid-2col resumen-grid">
            <div class="resumen-card programada skeleton"></div>
            <div class="resumen-card completada skeleton"></div>
        </div>
    }
    else
    {
        <div class="grid-2col resumen-grid">
            <div class="resumen-card programada" @onclick="GoActividades">
                <span class="resumen-numero">@dashboard?.TotalPendientes</span>
                <span class="resumen-label">Programadas</span>
                <i class="bi bi-arrow-right resumen-arrow"></i>
            </div>
            <div class="resumen-card completada" @onclick="GoActividades">
                <span class="resumen-numero">@dashboard?.TotalCompletadas</span>
                <span class="resumen-label">Completadas</span>
                <i class="bi bi-arrow-right resumen-arrow"></i>
            </div>
        </div>
    }

    @* Acciones rápidas *@
    <p class="section-title" style="margin-top:2rem;">Acciones rápidas</p>
    <div class="grid-2col actions-grid">
        <div class="action-card @(loadingCard == "empresa" ? "loading" : "")" @onclick="GoEmpresa">
            @if (loadingCard == "empresa")
            {
                <div class="card-loading"><div class="spinner small"></div></div>
            }
            <div class="card-icon-wrap" style="background:#eff6ff;">
                <i class="bi bi-building" style="color:#2563eb;"></i>
            </div>
            <div class="card-text">
                <span class="card-title">Nueva Empresa</span>
                <span class="card-desc">Registra un cliente o prospecto</span>
            </div>
            <i class="bi bi-arrow-right card-arrow"></i>
        </div>
        <div class="action-card @(loadingCard == "usuario" ? "loading" : "")" @onclick="GoUsuario">
            @if (loadingCard == "usuario")
            {
                <div class="card-loading"><div class="spinner small"></div></div>
            }
            <div class="card-icon-wrap" style="background:#f0fdf4;">
                <i class="bi bi-person-plus" style="color:#16a34a;"></i>
            </div>
            <div class="card-text">
                <span class="card-title">Nuevo Usuario</span>
                <span class="card-desc">Agrega acceso al sistema</span>
            </div>
            <i class="bi bi-arrow-right card-arrow"></i>
        </div>
        <div class="action-card @(loadingCard == "empleado" ? "loading" : "")" @onclick="GoEmpleado">
            @if (loadingCard == "empleado")
            {
                <div class="card-loading"><div class="spinner small"></div></div>
            }
            <div class="card-icon-wrap" style="background:#fdf4ff;">
                <i class="bi bi-people" style="color:#9333ea;"></i>
            </div>
            <div class="card-text">
                <span class="card-title">Nuevo Empleado</span>
                <span class="card-desc">Gestiona tu equipo de trabajo</span>
            </div>
            <i class="bi bi-arrow-right card-arrow"></i>
        </div>
        <div class="action-card @(loadingCard == "eventos" ? "loading" : "")" @onclick="GoEventos">
            @if (loadingCard == "eventos")
            {
                <div class="card-loading"><div class="spinner small"></div></div>
            }
            <div class="card-icon-wrap" style="background:#fff7ed;">
                <i class="bi bi-calendar-event" style="color:#ea580c;"></i>
            </div>
            <div class="card-text">
                <span class="card-title">Nuevo Evento</span>
                <span class="card-desc">Programa en Google Calendar</span>
            </div>
            <i class="bi bi-arrow-right card-arrow"></i>
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private DashboardActividadDto? dashboard;
    private bool cargando = true;
    private string? loadingCard;
    private int usuarioId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        usuarioId = authState.User.GetUsuarioId();
        dashboard = await ActividadService.ObtenerDashboardAsync(usuarioId, null, "Todas");
        cargando = false;
    }

    private void GoActividades()
    {
        Nav.NavigateTo("/dashboardActividades");
    }

    private async Task NavigateWithLoading(string key, string url)
    {
        if (loadingCard != null) return;
        loadingCard = key;
        StateHasChanged();
        await Task.Delay(150);
        Nav.NavigateTo(url);
    }

    private Task GoEmpresa() => NavigateWithLoading("empresa", "/empresas/crear");
    private Task GoUsuario() => NavigateWithLoading("usuario", "/usuarios/crear");
    private Task GoEmpleado() => NavigateWithLoading("empleado", "/empleados");
    private Task GoEventos() => NavigateWithLoading("eventos", "/google-eventos");
}