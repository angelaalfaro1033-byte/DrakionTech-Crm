@page "/empresas/editar/{EmpresaId:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IEmpresaService EmpresaService
@inject IPaisService PaisService
@inject ICiudadService CiudadService
@inject ISectorEmpresaService SectorEmpresaService
@inject IPrefijoTelefonicoService PrefijoTelefonicoService
@inject IContactoService ContactoService
@inject NavigationManager Navigation
@using DrakionTech.Crm.Data.Entities.Enums
@using DrakionTech.Crm.Business.DTOs.SectorEmpresa

<div class="form-card">

    @if (modelo is null)
    {
        <p>Cargando...</p>
    }
    else
    {
        <div class="form-header">
            <h1>Editar empresa</h1>
            <p>Actualiza la información de la empresa</p>
        </div>

        <EditForm Model="@modelo" OnValidSubmit="Guardar" FormName="EmpresaEditForm">
            <DataAnnotationsValidator />
            <ValidationSummary class="validation-summary" />

            <!-- SECCIÓN 1: Identificación -->
            <div class="form-section">
                <h3>Identificación</h3>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label required">Tipo de cliente</label>
                        <InputSelect class="form-select" @bind-Value="modelo.TipoCliente"
                                     @bind-Value:after="OnTipoClienteChanged">
                            <option value="@TipoCliente.Juridico">Persona Jurídica</option>
                            <option value="@TipoCliente.Natural">Persona Natural</option>
                        </InputSelect>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label required">Tipo de documento</label>
                        @if (modelo.TipoCliente == TipoCliente.Juridico)
                        {
                            <input class="form-control" value="NIT" readonly />
                        }
                        else
                        {
                            <InputSelect class="form-select" @bind-Value="modelo.TipoDocumento">
                                @foreach (var td in tiposDocumentoNatural)
                                {
                                    <option value="@td">@td.ToString()</option>
                                }
                            </InputSelect>
                        }
                    </div>

                    <div class="col-md-4">
                        <label class="form-label required">
                            @(modelo.TipoCliente == TipoCliente.Juridico ? "NIT" : "Número de documento")
                        </label>
                        <InputText class="form-control" @bind-Value="modelo.NumeroDocumento" />
                        <ValidationMessage For="() => modelo.NumeroDocumento" class="validation-message" />
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 2: Información general -->
            <div class="form-section">
                <h3>Información general</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label required">
                            @(modelo.TipoCliente == TipoCliente.Juridico ? "Razón social" : "Nombre completo")
                        </label>
                        <InputText class="form-control" @bind-Value="modelo.Nombre" />
                        <ValidationMessage For="() => modelo.Nombre" class="validation-message" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Representante legal</label>
                        <InputText class="form-control" @bind-Value="modelo.RepresentanteLegal" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Dirección</label>
                        <InputText class="form-control" @bind-Value="modelo.Direccion" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label required">País</label>
                        <InputSelect class="form-select" @bind-Value="modelo.PaisId"
                                     @bind-Value:after="OnPaisChanged">
                            @foreach (var pais in paises)
                            {
                                <option value="@pais.Id">@pais.Nombre</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => modelo.PaisId" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label required">Ciudad</label>
                        <InputSelect class="form-select" @bind-Value="modelo.CiudadId">
                            @foreach (var ciudad in ciudades)
                            {
                                <option value="@ciudad.Id">@ciudad.Nombre</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => modelo.CiudadId" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Teléfono</label>
                        <div class="input-group">
                            <input class="form-control" style="max-width:90px"
                                   value="@modelo.PrefijoTelefonicoCodigo" readonly />
                            <InputText class="form-control" placeholder="Número"
                                       @bind-Value="modelo.Telefono" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 3: Correos -->
            <div class="form-section">
                <h3>Correos electrónicos</h3>
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label required">Correo principal</label>
                        <InputText class="form-control" type="email"
                                   placeholder="empresa@dominio.com"
                                   @bind-Value="modelo.Correo" />
                        <ValidationMessage For="() => modelo.Correo" />
                    </div>
                </div>

                @for (int i = 0; i < modelo.Correos.Count; i++)
                {
                    var idx = i;
                    <div class="row g-2 mt-2 align-items-center">
                        <div class="col-md-8">
                            <InputText class="form-control" type="email"
                                       placeholder="Correo adicional"
                                       @bind-Value="modelo.Correos[idx].Correo" />
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-sm btn-outline-danger"
                                    @onclick="() => EliminarCorreo(idx)">
                                Eliminar
                            </button>
                        </div>
                    </div>
                }

                <button type="button" class="btn btn-sm btn-outline-secondary mt-2"
                        @onclick="AgregarCorreo">
                    + Agregar correo
                </button>
            </div>

            <!-- SECCIÓN 4: Contacto principal -->
            <div class="form-section">
                <h3>Contacto principal</h3>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Nombre</label>
                        <InputText class="form-control"
                                   @bind-Value="modelo.ContactoPrincipal!.Nombre" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Apellido</label>
                        <InputText class="form-control"
                                   @bind-Value="modelo.ContactoPrincipal!.Apellido" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Cargo</label>
                        <InputText class="form-control"
                                   @bind-Value="modelo.ContactoPrincipal!.Cargo" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Correo del contacto</label>
                        <InputText class="form-control" type="email"
                                   @bind-Value="modelo.ContactoPrincipal!.Email" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Teléfono del contacto</label>

                        <InputText class="form-control"
                                   @bind-Value="modelo.ContactoPrincipal!.Telefono" />

                        <ValidationMessage For="() => modelo.ContactoPrincipal!.Telefono" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Rol</label>
                        <InputSelect class="form-select"
                                     @bind-Value="modelo.ContactoPrincipal!.RolContactoId">
                            <option value="">-- Seleccione --</option>
                            @foreach (var rol in rolesContacto)
                            {
                                <option value="@rol.Id">@rol.Nombre</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                @* Contactos adicionales *@
                @for (int i = 0; i < modelo.ContactosAdicionales.Count; i++)
                {
                    var idx = i;
                    <hr class="mt-3" />
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <h6 class="mb-0">Contacto adicional @(idx + 1)</h6>
                        <button type="button" class="btn btn-sm btn-outline-danger"
                                @onclick="() => EliminarContacto(idx)">
                            Eliminar
                        </button>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-4">
                            <label class="form-label required">Nombre</label>
                            <InputText class="form-control" @bind-Value="modelo.ContactosAdicionales[idx].Nombre" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label required">Apellido</label>
                            <InputText class="form-control" @bind-Value="modelo.ContactosAdicionales[idx].Apellido" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cargo</label>
                            <InputText class="form-control" @bind-Value="modelo.ContactosAdicionales[idx].Cargo" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Correo</label>
                            <InputText class="form-control" type="email" @bind-Value="modelo.ContactosAdicionales[idx].Email" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Teléfono</label>

                            <InputText class="form-control"
                                       @bind-Value="modelo.ContactosAdicionales[idx].Telefono" />

                            <ValidationMessage For="() => modelo.ContactosAdicionales[idx].Telefono" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Rol</label>
                            <InputSelect class="form-select" @bind-Value="modelo.ContactosAdicionales[idx].RolContactoId">
                                <option value="">-- Seleccione --</option>
                                @foreach (var rol in rolesContacto)
                                {
                                    <option value="@rol.Id">@rol.Nombre</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                }

                <button type="button" class="btn btn-sm btn-outline-secondary mt-3"
                        @onclick="AgregarContacto">
                    + Agregar contacto
                </button>
            </div>

            <!-- SECCIÓN 5: Clasificación -->
            <div class="form-section">
                <h3>Clasificación</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Tamaño de empresa</label>
                        <InputSelect class="form-select" @bind-Value="modelo.Tamaño">
                            <option value="">-- Seleccione --</option>
                            @foreach (TamañoEmpresa t in Enum.GetValues(typeof(TamañoEmpresa)))
                            {
                                <option value="@t">@t.ToString()</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Sector</label>
                        <CreatableSelect TItem="SectorEmpresaDto"
                                         Items="sectoresEmpresa"
                                         ObtenerTexto="s => s.Nombre"
                                         ObtenerId="s => s.Id"
                                         Placeholder="Buscar o crear sector..."
                                         ValorSeleccionadoTexto="@sectorSeleccionadoTexto"
                                         OnSeleccionar="OnSectorSeleccionado"
                                         OnCrear="OnSectorCreado" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Subsector</label>
                        <CreatableSelect TItem="SubsectorEmpresaDto"
                                         Items="subsectoresFiltrados"
                                         ObtenerTexto="s => s.Nombre"
                                         ObtenerId="s => s.Id"
                                         Placeholder="@(modelo.SectorEmpresaId == null ? "Selecciona un sector primero" : "Buscar o crear subsector...")"
                                         ValorSeleccionadoTexto="@subsectorSeleccionadoTexto"
                                         OnSeleccionar="OnSubsectorSeleccionado"
                                         OnCrear="OnSubsectorCreado"
                                         Disabled="@(modelo.SectorEmpresaId == null)" />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Descripción</label>
                        <InputTextArea class="form-control" rows="3"
                                       @bind-Value="modelo.Descripcion"
                                       placeholder="Describe brevemente la empresa..." />
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 6: Fechas -->
            <div class="form-section">
                <h3>Fechas</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">
                            Fecha de creación de empresa
                        </label>

                        <InputDate class="form-control"
                                   @bind-Value="modelo.FechaCreacionEmpresa" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">
                            Fecha de registro en CRM
                        </label>

                        <InputDate class="form-control"
                                   @bind-Value="modelo.FechaRegistroCrm" />
                    </div>
                </div>
            </div>

            <!-- SECCIÓN 7: Seguimiento -->
            <div class="form-section">
                <h3>Seguimiento</h3>
                <div class="row g-3">
                    <div class="col-md-12">
                        <InputTextArea class="form-control" rows="3"
                                       @bind-Value="modelo.Seguimiento"
                                       placeholder="Notas de seguimiento..." />
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <button type="button" class="btn btn-outline-secondary ms-2"
                        @onclick="Cancelar">
                    Cancelar
                </button>
            </div>

        </EditForm>
    }
</div>

@code {
    [Parameter] public int EmpresaId { get; set; }

    private ActualizarEmpresaDto? modelo;

    private List<PaisDto> paises = new();
    private List<CiudadDto> ciudades = new();
    private List<SectorEmpresaDto> sectoresEmpresa = new();
    private List<SubsectorEmpresaDto> subsectoresFiltrados = new();
    private List<CatalogoDto> rolesContacto = new();

    private string sectorSeleccionadoTexto = string.Empty;
    private string subsectorSeleccionadoTexto = string.Empty;

    private string? sectorPendienteNombre = null;
    private string? subsectorPendienteNombre = null;

    private static readonly TipoDocumento[] tiposDocumentoNatural =
        { TipoDocumento.CC, TipoDocumento.CE, TipoDocumento.PA, TipoDocumento.RC, TipoDocumento.TI };

    protected override async Task OnInitializedAsync()
    {
        paises = (await PaisService.ObtenerTodosAsync()).ToList();
        if (!paises.Any()) throw new InvalidOperationException("No existen países configurados.");

        sectoresEmpresa = (await SectorEmpresaService.ObtenerTodosAsync()).ToList();
        rolesContacto = (await ContactoService.ObtenerRolesContactoAsync())
            .Select(r => new CatalogoDto { Id = r.Id, Nombre = r.Nombre }).ToList();

        var empresa = await EmpresaService.ObtenerPorIdAsync(EmpresaId);

        if (empresa.SectorEmpresaId.HasValue)
        {
            var sector = sectoresEmpresa.FirstOrDefault(s => s.Id == empresa.SectorEmpresaId);
            if (sector != null)
            {
                sectorSeleccionadoTexto = sector.Nombre;
                subsectoresFiltrados = (await SectorEmpresaService
                    .ObtenerSubsectoresPorSectorAsync(sector.Id)).ToList();
            }
        }

        if (empresa.SubsectorEmpresaId.HasValue)
        {
            var sub = subsectoresFiltrados.FirstOrDefault(s => s.Id == empresa.SubsectorEmpresaId);
            if (sub != null) subsectorSeleccionadoTexto = sub.Nombre;
        }

        // Cargar contacto principal
        var contactos = (await ContactoService.ObtenerPorEmpresaAsync(EmpresaId)).ToList();
        var principal = contactos.FirstOrDefault(c => c.EsPrincipal) ?? contactos.FirstOrDefault();

        modelo = new ActualizarEmpresaDto
        {
            TipoCliente = empresa.TipoCliente,
            TipoDocumento = empresa.TipoDocumento,
            NumeroDocumento = empresa.NumeroDocumento,
            Nombre = empresa.Nombre,
            Direccion = empresa.Direccion,
            PaisId = empresa.PaisId,
            CiudadId = empresa.CiudadId,
            Telefono = empresa.Telefono,
            PrefijoTelefonicoCodigo = empresa.PrefijoTelefonicoCodigo,
            Correo = empresa.Correo,
            Correos = empresa.Correos
                .Where(c => !c.EsPrincipal)
                .Select(c => new EmpresaCorreoDto { Id = c.Id, Correo = c.Correo })
                .ToList(),
            RepresentanteLegal = empresa.RepresentanteLegal,
            FechaCreacionEmpresa = empresa.FechaCreacionEmpresa,
            FechaRegistroCrm = empresa.FechaRegistroCrm,
            SectorEmpresaId = empresa.SectorEmpresaId,
            SubsectorEmpresaId = empresa.SubsectorEmpresaId,
            Tamaño = empresa.Tamaño,
            Descripcion = empresa.Descripcion,
            Seguimiento = empresa.Seguimiento,
            ContactoPrincipal = principal is null ? new() : new ContactoPrincipalDto
            {
                Nombre = principal.Nombre,
                Apellido = principal.Apellido,
                Cargo = principal.Cargo,
                Email = principal.Email,
                Telefono = principal.Telefono,
                RolContactoId = principal.RolContactoId
            },
            ContactosAdicionales = contactos
                .Where(c => !c.EsPrincipal)
                .Select(c => new ContactoAdicionalDto
                {
                    Nombre = c.Nombre,
                    Apellido = c.Apellido,
                    Cargo = c.Cargo,
                    Email = c.Email,
                    Telefono = c.Telefono,
                    RolContactoId = c.RolContactoId
                }).ToList(),
        };

        await CargarCiudades(modelo.PaisId);
        if (!ciudades.Any(c => c.Id == modelo.CiudadId))
            modelo.CiudadId = ciudades.First().Id;

        await CargarPrefijo(modelo.PaisId);
    }

    private void OnTipoClienteChanged()
    {
        modelo!.TipoDocumento = modelo.TipoCliente == TipoCliente.Juridico
            ? TipoDocumento.NIT
            : TipoDocumento.CC;
    }

    private async Task OnPaisChanged()
    {
        await CargarCiudades(modelo!.PaisId);
        modelo.CiudadId = ciudades.First().Id;
        await CargarPrefijo(modelo.PaisId);
    }

    private async Task CargarCiudades(int paisId)
    {
        ciudades = (await CiudadService.ObtenerPorPaisAsync(paisId)).ToList();
        if (!ciudades.Any())
            throw new InvalidOperationException("El país no tiene ciudades configuradas.");
    }

    private async Task CargarPrefijo(int paisId)
        => modelo!.PrefijoTelefonicoCodigo =
            await PrefijoTelefonicoService.ObtenerCodigoPorPaisAsync(paisId);

    private async Task CargarSubsectores(int sectorId)
        => subsectoresFiltrados =
            (await SectorEmpresaService.ObtenerSubsectoresPorSectorAsync(sectorId)).ToList();

    private async Task OnSectorSeleccionado(SectorEmpresaDto? sector)
    {
        sectorPendienteNombre = null;
        subsectorPendienteNombre = null;

        if (sector is null)
        {
            modelo.SectorEmpresaId = null;
            modelo.SubsectorEmpresaId = null;
            sectorSeleccionadoTexto = string.Empty;
            subsectorSeleccionadoTexto = string.Empty;
            subsectoresFiltrados.Clear();
            return;
        }

        modelo.SectorEmpresaId = sector.Id;
        sectorSeleccionadoTexto = sector.Nombre;
        await CargarSubsectores(sector.Id);
        modelo.SubsectorEmpresaId = null;
        subsectorSeleccionadoTexto = string.Empty;
    }

    private Task OnSectorCreado(string nombre)
    {
        modelo.SectorEmpresaId = null;
        sectorPendienteNombre = nombre;
        sectorSeleccionadoTexto = nombre;
        subsectoresFiltrados.Clear();
        modelo.SubsectorEmpresaId = null;
        subsectorSeleccionadoTexto = string.Empty;
        subsectorPendienteNombre = null;
        return Task.CompletedTask;
    }

    private void OnSubsectorSeleccionado(SubsectorEmpresaDto sub)
    {
        modelo!.SubsectorEmpresaId = sub?.Id;
        subsectorSeleccionadoTexto = sub?.Nombre ?? string.Empty;
    }

    private Task OnSubsectorCreado(string nombre)
    {
        modelo.SubsectorEmpresaId = null;
        subsectorPendienteNombre = nombre;
        subsectorSeleccionadoTexto = nombre;
        return Task.CompletedTask;
    }

    private void AgregarCorreo() => modelo!.Correos.Add(new EmpresaCorreoDto());
    private void EliminarCorreo(int index) => modelo!.Correos.RemoveAt(index);
    private void AgregarContacto() => modelo!.ContactosAdicionales.Add(new ContactoAdicionalDto());
    private void EliminarContacto(int index) => modelo!.ContactosAdicionales.RemoveAt(index);

    private async Task Guardar()
    {
        if (sectorPendienteNombre is not null)
        {
            var nuevoSector = await SectorEmpresaService.CrearYObtenerAsync(sectorPendienteNombre);
            modelo!.SectorEmpresaId = nuevoSector.Id;
        }

        if (subsectorPendienteNombre is not null && modelo!.SectorEmpresaId.HasValue)
        {
            var nuevoSub = await SectorEmpresaService
                .CrearSubsectorYObtenerAsync(subsectorPendienteNombre, modelo.SectorEmpresaId.Value);
            modelo.SubsectorEmpresaId = nuevoSub.Id;
        }

        await EmpresaService.ActualizarAsync(EmpresaId, modelo!);
        Navigation.NavigateTo("/empresas");
    }

    private void Cancelar() => Navigation.NavigateTo("/empresas");
}