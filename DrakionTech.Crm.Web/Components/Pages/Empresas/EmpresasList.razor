@page "/empresas"
@attribute [Authorize]
@using DrakionTech.Crm.Business.DTOs.Empresa
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Web.Components
@inject IEmpresaService EmpresaService
@inject IJSRuntime JS

<div class="empresas-container">

    <div class="page-header">
        <div>
            <h1 class="page-title">Empresas</h1>
            <p class="page-subtitle">Gestiona las empresas de tu CRM</p>
        </div>
        <a class="btn btn-primary" href="/empresas/crear">
            + Nueva Empresa
        </a>
    </div>

    <FiltroTabla TItem="EmpresaDto"
                 PlaceholderBusqueda="Buscar por nombre, NIT o correo..."
                 MostrarFiltroEstado="true"
                 OnFiltroChanged="OnFiltroChanged" />

    @if (cargando)
    {
        <p>Cargando empresas...</p>
    }
    else if (!empresas.Any())
    {
        <div class="alert alert-info">
            No hay empresas registradas.
        </div>
    }
    else
    {
        <div class="ui-card">
            <table class="ui-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>NIT</th>
                        <th>País</th>
                        <th>Email</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var empresa in empresas)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a href="/empresas/@empresa.Id" class="link-tabla">
                                    @empresa.Nombre
                                </a>
                            </td>
                            <td>@empresa.Nit</td>
                            <td>@empresa.PaisNombre</td>
                            <td>@empresa.Correo</td>
                            <td>
                                <span class="badge @(empresa.Activa ? "bg-success" : "bg-secondary")">
                                    @(empresa.Activa ? "Activa" : "Inactiva")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="ui-actions">
                                    <a href="/empresas/@empresa.Id" title="Ver">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="/empresas/editar/@empresa.Id" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (empresa.Activa)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-success"
                                                title="Desactivar"
                                                @onclick="() => Desactivar(empresa.Id)">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-secondary"
                                                title="Activar"
                                                @onclick="() => Activar(empresa.Id)">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private List<EmpresaDto> empresas = new();
    private bool cargando = true;
    private string? busqueda;
    private bool? soloActivas;

    protected override async Task OnInitializedAsync() => await Cargar();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("initTooltips");
    }

    private async Task Cargar()
    {
        cargando = true;
        StateHasChanged();
        empresas = (await EmpresaService.ObtenerTodasAsync(busqueda, soloActivas)).ToList();
        cargando = false;
    }

    private async Task OnFiltroChanged(Dictionary<string, string?> valores)
    {
        busqueda = valores.GetValueOrDefault("busqueda");
        var estado = valores.GetValueOrDefault("estado");
        soloActivas = string.IsNullOrWhiteSpace(estado) ? null : bool.Parse(estado);
        await Cargar();
    }

    private async Task Activar(int id)
    {
        await EmpresaService.ActivarAsync(id);
        await Cargar();
    }

    private async Task Desactivar(int id)
    {
        await EmpresaService.DesactivarAsync(id);
        await Cargar();
    }
}