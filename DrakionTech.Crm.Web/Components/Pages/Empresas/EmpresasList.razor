@page "/empresas"
@attribute [Authorize]
@using DrakionTech.Crm.Business.DTOs.Empresa
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Web.Components
@inject IEmpresaService EmpresaService
@inject IJSRuntime JS
@using DrakionTech.Crm.Web.Shared
@inherits PaginacionBase

<div class="list-header">
    <div>
        <h2>Empresas</h2>
        <p>Gestiona las empresas de tu CRM</p>
    </div>
    <a class="btn btn-primary d-flex align-items-center gap-2" href="/empresas/crear">
        <i class="bi bi-plus-lg"></i> Nueva Empresa
    </a>
</div>

<FiltroTabla TItem="EmpresaDto"
             PlaceholderBusqueda="Buscar por nombre, NIT o correo..."
             MostrarFiltroEstado="true"
             OnFiltroChanged="OnFiltroChanged" />

<div class="ui-card">
    @if (cargando)
    {
        <div class="ui-empty">
            <div class="spinner-border spinner-border-sm mb-2"></div>
            <p>Cargando empresas…</p>
        </div>
    }
    else if (!empresas.Any())
    {
        <div class="ui-empty">
            <i class="bi bi-building"></i>
            <p>No hay empresas registradas.</p>
        </div>
    }
    else
    {
        <table class="ui-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>NIT</th>
                    <th>País</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Última actualización</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var empresa in empresas)
                {
                    <tr>
                        <td class="col-primary">
                            <a href="/empresas/@empresa.Id">@empresa.Nombre</a>
                        </td>
                        <td class="col-secondary">@empresa.NumeroDocumento</td>
                        <td class="col-secondary">@empresa.PaisNombre</td>
                        <td class="col-secondary">@empresa.Correo</td>
                        <td>
                            @if (empresa.Activa)
                            {
                                <span class="badge badge-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactiva</span>
                            }
                        </td>
                        <td><AuditLastUpdated AuditInfo="empresa.AuditInfo" /></td>
                        <td>
                            <div class="ui-actions">
                                <a href="/empresas/@empresa.Id" title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/empresas/editar/@empresa.Id" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (empresa.Activa)
                                {
                                    <button type="button" class="btn btn-sm btn-success btn-toggle"
                                            title="Desactivar" @onclick="() => Desactivar(empresa.Id)">
                                        <i class="bi bi-toggle-on"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-secondary btn-toggle"
                                            title="Activar" @onclick="() => Activar(empresa.Id)">
                                        <i class="bi bi-toggle-off"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <Paginacion PaginaActual="paginaActual"
                    TotalPaginas="totalPaginas"
                    OnPaginaChanged="IrAPagina" />
    }
</div>

@code {
    private List<EmpresaDto> empresas = new();
    private bool cargando = true;
    private string? busqueda;
    private bool? soloActivas;

    protected override async Task OnInitializedAsync() => await Cargar();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("initTooltips");
    }

    private async Task Cargar()
    {
        cargando = true;
        StateHasChanged();
        var resultado = await EmpresaService.ObtenerTodasConPaginacionAsync(
            busqueda,
            soloActivas,
            paginaActual,
            tamañoPagina);

        empresas = resultado.Items;

        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;
        cargando = false;
    }

    private async Task OnFiltroChanged(Dictionary<string, string?> valores)
    {
        busqueda = valores.GetValueOrDefault("busqueda");
        var estado = valores.GetValueOrDefault("estado");
        soloActivas = string.IsNullOrWhiteSpace(estado) ? null : bool.Parse(estado);
        paginaActual = 1;
        await Cargar();
    }

    private async Task Activar(int id)
    {
        await EmpresaService.ActivarAsync(id);
        await Cargar();
    }

    private async Task Desactivar(int id)
    {
        await EmpresaService.DesactivarAsync(id);
        await Cargar();
    }

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(pagina, Cargar);
    }
}
