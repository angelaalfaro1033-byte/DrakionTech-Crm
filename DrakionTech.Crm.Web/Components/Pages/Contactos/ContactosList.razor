@page "/empresas/{EmpresaId:int}/contactos"
@attribute [Authorize]
@inject IEmpresaService EmpresaService
@inject IContactoService ContactoService

@if (empresa is null)
{
    <p>Cargando...</p>
}
else
{
    <EmpresaComponente Empresa="empresa">
        <div class="detail-section-header">
            <div>
                <h5 class="oport-title">Contactos</h5>
                <small>Gestión de contactos de la empresa</small>
            </div>

            <a class="btn btn-primary detail-section-header__action d-flex align-items-center gap-2"
               href="/empresas/@EmpresaId/contactos/crear">
                <i class="bi bi-plus-lg"></i>
                Nuevo contacto
            </a>
        </div>

        @if (contactos is null)
        {
            <p class="text-muted small">Cargando contactos...</p>
        }
        else if (!contactos.Any())
        {
            <div class="oport-empty">
                <p>Esta empresa no tiene contactos registrados.</p>
            </div>
        }
        else
        {
            <div class="ui-toolbar detail-toolbar">
                <div class="ui-search">
                    <i class="bi bi-search"></i>
                    <input class="form-control"
                           placeholder="Buscar contacto..."
                           @bind="busqueda"
                           @bind:event="oninput" />
                </div>
                <select class="form-select"
                        @bind="rolSeleccionado">
                    <option value="">-- Todos los roles --</option>
                    @foreach (var rol in roles)
                    {
                        <option value="@rol">@rol</option>
                    }
                </select>
            </div>

            <div class="ui-card">
                <table class="ui-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Teléfono</th>
                            <th>Rol</th>
                            <th>Última actualización</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contacto in contactosFiltrados!)
                        {
                            <tr>
                                <td style="font-weight:500;color:var(--text-main)">
                                    @contacto.NombreCompleto
                                </td>
                                <td style="font-size:13px;color:var(--text-muted)">
                                    @contacto.Email
                                </td>
                                <td style="font-size:13px">
                                    @(string.IsNullOrEmpty(contacto.Telefono) ? "—" : contacto.Telefono)
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(contacto.RolNombre))
                                    {
                                        <span class="oport-badge oport-badge--rol">
                                            @contacto.RolNombre
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted);font-size:13px">—</span>
                                    }
                                </td>
                                <td>
                                    <AuditLastUpdated AuditInfo="contacto.AuditInfo" />
                                </td>
                                <td>
                                    <div class="ui-actions">
                                        <a href="/contactos/editar/@contacto.Id" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </EmpresaComponente>
}

@code {
    [Parameter] public int EmpresaId { get; set; }

    private EmpresaDto? empresa;

    private IEnumerable<ContactoDto>? contactos;
    private IEnumerable<ContactoDto>? contactosFiltrados;

    private List<string> roles = new();

    private string? _busqueda;
    private string? _rolSeleccionado;

    private string? busqueda
    {
        get => _busqueda;
        set
        {
            _busqueda = value;
            AplicarFiltros();
        }
    }

    private string? rolSeleccionado
    {
        get => _rolSeleccionado;
        set
        {
            _rolSeleccionado = value;
            AplicarFiltros();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        empresa = await EmpresaService.ObtenerPorIdAsync(EmpresaId);
        contactos = await ContactoService.ObtenerPorEmpresaAsync(EmpresaId);

        contactosFiltrados = contactos;

        roles = contactos
            .Where(c => !string.IsNullOrWhiteSpace(c.RolNombre))
            .Select(c => c.RolNombre!)
            .Distinct()
            .OrderBy(r => r)
            .ToList();
    }

    private void AplicarFiltros()
    {
        if (contactos is null) return;

        var query = contactos.AsQueryable();

        if (!string.IsNullOrWhiteSpace(busqueda))
        {
            var texto = busqueda.ToLower();

            query = query.Where(c =>
                (c.NombreCompleto != null && c.NombreCompleto.ToLower().Contains(texto)) ||
                (c.Email != null && c.Email.ToLower().Contains(texto)) ||
                (c.Telefono != null && c.Telefono.ToLower().Contains(texto))
            );
        }

        if (!string.IsNullOrWhiteSpace(rolSeleccionado))
        {
            query = query.Where(c => c.RolNombre == rolSeleccionado);
        }

        contactosFiltrados = query.ToList();
    }
}
