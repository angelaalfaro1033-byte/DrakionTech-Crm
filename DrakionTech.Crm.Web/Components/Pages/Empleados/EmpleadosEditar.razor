@page "/empleados/editar/{id:int}"
@attribute [Authorize]
@using DrakionTech.Crm.Business.DTOs.Empleado
@inject IEmpleadoService EmpleadoService
@inject NavigationManager Nav

<div class="empleados-container">

    <div class="page-header">
        <div>
            <h1 class="page-title">Editar empleado</h1>
            <p class="page-subtitle">Actualiza la información</p>
        </div>
    </div>

    @if (cargando)
    {
        <div class="ui-card">
            <p>Cargando información...</p>
        </div>
    }
    else
    {
        <div class="ui-card">
            @if (!string.IsNullOrEmpty(error))
            {
                <ul class="validation-summary">
                    @foreach (var err in error.Split(" | "))
                    {
                        <li>@err</li>
                    }
                </ul>
            }
            <EmpleadoForm Model="empleado"
                          OnValidSubmit="Guardar"
                          OnCancel="Cancelar"
                          TextoBoton="Actualizar" />
        </div>
    }

</div>

@code {
    [Parameter] public int id { get; set; }

    private CrearEmpleadoDto empleado = new();
    private bool cargando = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var e = await EmpleadoService.ObtenerPorIdAsync(id);

            empleado = new CrearEmpleadoDto
{
            TipoDocumento   = e.TipoDocumento,
            NumeroDocumento = e.NumeroDocumento,
            Nombre          = e.Nombre,
            Apellido        = e.Apellido,
            Email           = e.Email,
            RolUsuarioId    = e.RolUsuarioId ?? 0,
            EspecialidadId  = e.EspecialidadId ?? 0,
            Salario         = e.Salario
        };
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task Guardar()
    {
        try
        {
            var dto = new ActualizarEmpleadoDto
{
                Id              = id,
                TipoDocumento   = empleado.TipoDocumento,
                NumeroDocumento = empleado.NumeroDocumento,
                Nombre          = empleado.Nombre,
                Apellido        = empleado.Apellido,
                Email           = empleado.Email,
                RolUsuarioId    = empleado.RolUsuarioId,
                EspecialidadId  = empleado.EspecialidadId,
                Salario         = empleado.Salario
            };

            await EmpleadoService.EditarAsync(dto);
            Nav.NavigateTo("/empleados");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void Cancelar()
    {
        Nav.NavigateTo("/empleados");
    }
}