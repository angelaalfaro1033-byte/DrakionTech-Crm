@page "/empleados"
@attribute [Authorize]
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Business.DTOs.Empleado
@using DrakionTech.Crm.Web.Components
@inject IEmpleadoService EmpleadoService
@using DrakionTech.Crm.Web.Shared
@inherits PaginacionBase

<div class="list-header">
    <div>
        <h2>Empleados</h2>
        <p>Gestiona los empleados del CRM</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary d-flex align-items-center gap-2" href="/empleados/crear">
            <i class="bi bi-plus-lg"></i> Nuevo Empleado
        </a>
        <a class="btn btn-secondary d-flex align-items-center gap-2" href="/empleados/importar">
            <i class="bi bi-file-earmark-excel"></i> Importar Excel
        </a>
    </div>
</div>

<FiltroTabla TItem="EmpleadoListDto"
             PlaceholderBusqueda="Buscar por nombre, email o cargo..."
             MostrarFiltroEstado="true"
             OnFiltroChanged="OnFiltroChanged" />

<div class="ui-card">
    @if (cargando)
    {
        <div class="ui-empty">
            <div class="spinner-border spinner-border-sm mb-2"></div>
            <p>Cargando empleados…</p>
        </div>
    }
    else if (!empleados.Any())
    {
        <div class="ui-empty">
            <i class="bi bi-people"></i>
            <p>No hay empleados registrados.</p>
        </div>
    }
    else
    {
        <table class="ui-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Especialidad</th>
                    <th>Estado</th>
                    <th>Última actualización</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in empleados)
                {
                    <tr>
                        <td class="col-primary">@item.Nombre @item.Apellido</td>
                        <td class="col-secondary">@item.Email</td>
                        <td class="col-secondary">@item.Especialidad</td>
                        <td>
                            @if (item.Activo)
                            {
                                <span class="badge badge-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactivo</span>
                            }
                        </td>
                        <td><AuditLastUpdated AuditInfo="item.AuditInfo" /></td>
                        <td>
                            <div class="ui-actions">
                                <a href="/empleados/editar/@item.Id" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (item.Activo)
                                {
                                    <button type="button" class="btn btn-sm btn-success btn-toggle"
                                            title="Desactivar"
                                            @onclick="() => CambiarEstado(item.Id, EmpleadoService.DesactivarAsync)">
                                        <i class="bi bi-toggle-on"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-sm btn-secondary btn-toggle"
                                            title="Activar"
                                            @onclick="() => CambiarEstado(item.Id, EmpleadoService.ActivarAsync)">
                                        <i class="bi bi-toggle-off"></i>
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <Paginacion PaginaActual="paginaActual"
                    TotalPaginas="totalPaginas"
                    OnPaginaChanged="IrAPagina" />
    }
</div>

@code {
    private List<EmpleadoListDto> empleados = new();
    private bool cargando = true;
    private string? busqueda;
    private bool? soloActivos;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        cargando = true;
        StateHasChanged();
        var resultado = await EmpleadoService.ObtenerTodosConPaginacionAsync(
            busqueda,
            soloActivos,
            paginaActual,
            tamañoPagina);

        empleados = resultado.Items;
        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;

        cargando = false;
    }

    private async Task OnFiltroChanged(Dictionary<string, string?> valores)
    {
        busqueda = valores.GetValueOrDefault("busqueda");
        var estado = valores.GetValueOrDefault("estado");
        soloActivos = string.IsNullOrWhiteSpace(estado) ? null : bool.Parse(estado);
        paginaActual = 1;
        await Cargar();
    }

    private async Task CambiarEstado(int id, Func<int, Task> accion)
    {
        await accion(id);
        await Cargar();
    }

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(pagina, Cargar);
    }

}
