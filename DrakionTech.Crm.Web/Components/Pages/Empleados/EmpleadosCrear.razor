@page "/empleados/crear"
@attribute [Authorize]
@using DrakionTech.Crm.Business.DTOs.Empleado
@inject IEmpleadoService EmpleadoService
@inject NavigationManager Nav

<div class="empleados-container">
    <div class="form-card">
        <div class="form-header">
            <h1>Crear empleado</h1>
            <p>Registra un nuevo empleado</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMensaje))
        {
            <ul class="validation-summary">
                @foreach (var err in errorMensaje.Split(" | "))
                {
                    <li>@err</li>
                }
            </ul>
        }

        <EmpleadoForm Model="empleado"
                      OnValidSubmit="Guardar"
                      OnCancel="Cancelar"
                      TextoBoton="Crear" />
    </div>
</div>

@code {
    private CrearEmpleadoDto empleado = new();

    private string? errorMensaje;

    private async Task Guardar()
    {
        try
        {
            errorMensaje = null;

            await EmpleadoService.CrearAsync(empleado);

            Nav.NavigateTo("/empleados");
        }
        catch (Exception ex)
        {
            errorMensaje = ex.Message;
        }
    }

    private void Cancelar()
    {
        Nav.NavigateTo("/empleados");
    }
}