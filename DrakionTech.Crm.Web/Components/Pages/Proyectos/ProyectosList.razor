@page "/proyectos"
@using DrakionTech.Crm.Business.DTOs.Proyecto
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Data.Entities.Enums
@using DrakionTech.Crm.Web.Components
@inject IProyectoService ProyectoService
@inject NavigationManager Nav
@using DrakionTech.Crm.Web.Shared
@inherits PaginacionBase

<div class="list-header">
    <div>
        <h2>Proyectos</h2>
        <p>Gestión de proyectos asociados a áreas</p>
    </div>
    <button type="button" class="btn btn-primary d-flex align-items-center gap-2"
            @onclick='() => Nav.NavigateTo("/proyectos/crear")'>
        <i class="bi bi-plus-lg"></i> Nuevo Proyecto
    </button>
</div>

<FiltroTabla TItem="ProyectoDto"
             PlaceholderBusqueda="Buscar proyecto..."
             MostrarFiltroEstado="false"
             OnFiltroChanged="AplicarFiltro" />

<div class="ui-card">
    @if (_cargando)
    {
        <div class="ui-empty">
            <div class="spinner-border spinner-border-sm mb-2"></div>
            <p>Cargando proyectos…</p>
        </div>
    }
    else if (!_proyectos.Any())
    {
        <div class="ui-empty">
            <i class="bi bi-kanban"></i>
            <p>No hay proyectos registrados.</p>
        </div>
    }
    else
    {
        <table class="ui-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Empresa</th>
                    <th>Área</th>
                    <th>Responsable</th>
                    <th>Etapa</th>
                    <th>Estado</th>
                    <th>Fecha Inicio</th>
                    <th>Última actualización</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _proyectos)
                {
                    <tr>
                        <td class="col-primary">@p.Nombre</td>
                        <td class="col-secondary">@(p.EmpresaNombre ?? "—")</td>
                        <td class="col-secondary">@p.AreaNombre</td>
                        <td class="col-secondary">@p.ResponsableNombre</td>
                        <td>
                            <span class="badge badge-secondary">@p.EtapaTexto</span>
                        </td>
                        <td>
                            <span class="badge @ObtenerBadge(p.Estado)">@p.EstadoTexto</span>
                        </td>
                        <td class="col-secondary">@p.FechaInicio.ToShortDateString()</td>
                        <td><AuditLastUpdated AuditInfo="p.AuditInfo" /></td>
                        <td>
                            <div class="ui-actions">
                                <button type="button" class="btn btn-sm btn-outline-primary"
                                        @onclick="() => AbrirModal(p)"
                                        title="Cambiar etapa">
                                    Cambiar etapa
                                </button>
                                <a href="/proyectos/detalle/@p.Id" title="Detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/proyectos/editar/@p.Id" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-link p-0 text-muted"
                                        @onclick="() => EliminarAsync(p.Id)"
                                        title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <Paginacion PaginaActual="paginaActual"
                    TotalPaginas="totalPaginas"
                    OnPaginaChanged="IrAPagina" />
    }
</div>

@if (_mostrarModal && _proyectoSeleccionado is not null)
{
    var siguiente = ProyectoService.ObtenerSiguienteEtapa(_proyectoSeleccionado.EtapaFlujo);

    <div class="modal-backdrop-custom"></div>

    <div class="modal-custom">
        <div class="modal-custom-header">
            Cambiar etapa del proyecto
        </div>

        <div class="modal-custom-body">

            @if (_errorModal is not null)
            {
                <div class="alert alert-danger">@_errorModal</div>
            }

            <p>Etapa actual: <strong>@_proyectoSeleccionado.EtapaTexto</strong></p>

            @if (siguiente is not null)
            {
                <p class="modal-etapa-siguiente">
                    Siguiente etapa: <strong>@ObtenerDescripcionEtapa(siguiente.Value)</strong>
                </p>

                <div class="mb-3">
                    <label class="form-label">% IVA</label>
                    <input type="number" class="form-control" @bind="_ivaNueva" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Valor calculado</label>
                    <input type="number" class="form-control" @bind="_valorCalculado" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Observaciones</label>
                    <textarea class="form-control" rows="3" @bind="_observacionesModal"></textarea>
                </div>
            }
            else
            {
                <div class="alert alert-success">
                    El proyecto ya está en la etapa final: <strong>Cierre del proyecto</strong>.
                </div>
            }

        </div>

        <div class="modal-custom-footer">
            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">
                Cancelar
            </button>
            @if (siguiente is not null)
            {
                <button type="button" class="btn btn-primary" @onclick="ConfirmarCambioEtapa">
                    Confirmar
                </button>
            }
        </div>
    </div>
}

@code {
    private List<ProyectoDto> _proyectos = new();
    private string? busqueda;
    private bool _cargando = true;

    protected override async Task OnInitializedAsync() => await CargarAsync();

    private async Task CargarAsync()
    {
        _cargando = true;

        var resultado =
            await ProyectoService.ObtenerTodosConPaginacionAsync(
                busqueda,
                paginaActual,
                tamañoPagina);

        _proyectos = resultado.Items;

        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;

        _cargando = false;
    }

    private async Task AplicarFiltro(Dictionary<string, string?> filtros)
    {
        busqueda = filtros.GetValueOrDefault("busqueda");

        paginaActual = 1;

        await CargarAsync();
    }

    private async Task EliminarAsync(int id)
    {
        await ProyectoService.EliminarAsync(id);
        await CargarAsync();
    }

    private string ObtenerBadge(EstadoProyecto estado) => estado switch
    {
        EstadoProyecto.Activo => "badge-success",
        EstadoProyecto.Inactivo => "badge-secondary",
        _ => ""
    };

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(pagina, CargarAsync);
    }
    private bool _mostrarModal;
    private ProyectoDto? _proyectoSeleccionado;
    private decimal? _ivaNueva;
    private decimal? _valorCalculado;
    private string? _observacionesModal;
    private string? _errorModal;

    private void AbrirModal(ProyectoDto p)
    {
        _proyectoSeleccionado = p;
        _ivaNueva = null;
        _valorCalculado = null;
        _observacionesModal = null;
        _errorModal = null;
        _mostrarModal = true;
    }

    private void CerrarModal()
    {
        _mostrarModal = false;
        _proyectoSeleccionado = null;
    }

    private async Task ConfirmarCambioEtapa()
    {
        if (_proyectoSeleccionado is null) return;

        var siguiente = ProyectoService.ObtenerSiguienteEtapa(_proyectoSeleccionado.EtapaFlujo);
        if (siguiente is null) return;

        try
        {
            await ProyectoService.CambiarEtapaAsync(new CambiarEtapaProyectoDto
                {
                    ProyectoId = _proyectoSeleccionado.Id,
                    NuevaEtapa = siguiente.Value,
                    PorcentajeIva = _ivaNueva,
                    ValorCalculado = _valorCalculado,
                    Observaciones = _observacionesModal
                });

            CerrarModal();
            await CargarAsync();
        }
        catch (Exception ex)
        {
            _errorModal = ex.Message;
        }
    }

    private string ObtenerDescripcionEtapa(EtapaFlujoProyecto e) => e switch
    {
        EtapaFlujoProyecto.FirmaContrato => "Firma de contrato",
        EtapaFlujoProyecto.PagoProyecto => "Pago del proyecto",
        EtapaFlujoProyecto.ConformacionEquipo => "Conformación del equipo",
        EtapaFlujoProyecto.ReunionInicial => "Reunión inicial",
        EtapaFlujoProyecto.InformacionGeneral => "Información general",
        EtapaFlujoProyecto.EjecucionProyecto => "Ejecución del proyecto",
        EtapaFlujoProyecto.SeguimientoFases => "Seguimiento de fases",
        EtapaFlujoProyecto.ActasEntregaFase => "Actas de entrega de fase",
        EtapaFlujoProyecto.ReunionCierre => "Reunión de cierre",
        EtapaFlujoProyecto.ActaFinal => "Acta final",
        EtapaFlujoProyecto.Otrosi => "Otrosí",
        EtapaFlujoProyecto.Calificacion => "Calificación",
        EtapaFlujoProyecto.CierreProyecto => "Cierre del proyecto",
        _ => e.ToString()
    };
}
