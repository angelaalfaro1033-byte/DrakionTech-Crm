@page "/marketing/metricas"
@attribute [Authorize]

@using DrakionTech.Crm.Business.DTOs.Marketing
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Web.Components
@using DrakionTech.Crm.Web.Shared

@inject IPublicacionMarketingService MarketingService

@inherits PaginacionBase

<div class="list-header">
    <div>
        <h2>Marketing</h2>
        <p>Seguimiento mensual y métricas por canal</p>
    </div>
</div>

<MarketingTabs />

<div class="detail-section-header mt-3">
    <div>
        <h5>Métricas</h5>
        <small class="text-muted">Seguimiento mensual y métricas por canal</small>
    </div>
    <a class="btn btn-primary d-flex align-items-center gap-2 detail-section-header__action"
       href="/marketing/crear-metrica">
        <i class="bi bi-plus-lg"></i> Agregar métrica
    </a>
</div>

<FiltroTabla TItem="MetricaPublicacionDto"
             PlaceholderBusqueda="Buscar publicación o canal..."
             MostrarFiltroEstado="false"
             OnFiltroChanged="OnFiltroChanged" />

<div class="ui-card">
    @if (_cargando)
    {
        <div class="ui-empty">
            <div class="spinner-border spinner-border-sm mb-2"></div>
            <p>Cargando métricas…</p>
        </div>
    }
    else if (!_metricas.Any())
    {
        <div class="ui-empty">
            <i class="bi bi-bar-chart"></i>
            <p>No hay métricas registradas.</p>
        </div>
    }
    else
    {
        <table class="ui-table">
            <thead>
                <tr>
                    <th>Publicación</th>
                    <th>Canal</th>
                    <th>Fecha</th>
                    <th>Visualizaciones</th>
                    <th>Reacciones</th>
                    <th>Alcance</th>
                    <th>Comercial</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var metrica in _metricas)
                {
                    <tr>
                        <td class="col-primary">@metrica.PublicacionNombre</td>
                        <td class="col-secondary">@metrica.RedSocialNombre</td>
                        <td class="col-secondary">@metrica.FechaRegistro.ToString("dd/MM/yyyy")</td>
                        <td class="col-secondary">@metrica.Visualizaciones</td>
                        <td class="col-secondary">@metrica.Reacciones</td>
                        <td class="col-secondary">@metrica.Alcance</td>
                        <td class="col-secondary">@(metrica.ContactoAreaComercial ? "Sí" : "No")</td>
                        <td>
                            <div class="ui-actions">
                                <a href="/marketing/editar-metrica/@metrica.Id" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <Paginacion PaginaActual="paginaActual"
                    TotalPaginas="totalPaginas"
                    OnPaginaChanged="IrAPagina" />
    }
</div>

@code {
    private List<MetricaPublicacionDto> _metricas = new();

    private bool _cargando = true;

    private string? _busqueda;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        _cargando = true;
        StateHasChanged();

        var resultado = await MarketingService.ObtenerMetricasConPaginacionAsync(
            _busqueda,
            paginaActual,
            tamañoPagina);

        _metricas = resultado.Items;
        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;

        _cargando = false;
    }

    private async Task OnFiltroChanged(Dictionary<string, string?> valores)
    {
        _busqueda = valores.GetValueOrDefault("busqueda");
        paginaActual = 1;

        await Cargar();
    }

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(pagina, Cargar);
    }
}