@page "/marketing/publicaciones"
@attribute [Authorize]

@using DrakionTech.Crm.Business.DTOs.Marketing
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Web.Components
@using DrakionTech.Crm.Web.Shared

@inject IPublicacionMarketingService MarketingService

@inherits PaginacionBase

<div class="list-header">
    <div>
        <h2>Marketing</h2>
        <p>Gestiona campañas, publicaciones y material publicitario</p>
    </div>
</div>

<MarketingTabs />

<div class="detail-section-header mt-3">
    <div>
        <h5>Publicaciones</h5>
        <small class="text-muted">Gestión de publicaciones</small>
    </div>
    <a class="btn btn-primary detail-section-header__action"
       href="/marketing/crear-publicacion">
        <i class="bi bi-plus-lg"></i> Nueva publicación
    </a>
</div>

<FiltroTabla TItem="PublicacionMarketingDto"
             PlaceholderBusqueda="Buscar campaña o responsable..."
             MostrarFiltroEstado="false"
             OnFiltroChanged="OnFiltroChanged" />

<div class="ui-card">
    @if (cargando)
    {
        <div class="ui-empty">
            <div class="spinner-border spinner-border-sm mb-2"></div>
            <p>Cargando publicaciones…</p>
        </div>
    }
    else if (!publicaciones.Any())
    {
        <div class="ui-empty">
            <i class="bi bi-megaphone"></i>
            <p>No hay publicaciones registradas.</p>
        </div>
    }
    else
    {
        <table class="ui-table">
            <thead>
                <tr>
                    <th>Campaña</th>
                    <th>Responsable</th>
                    <th>Programada</th>
                    <th>Estado</th>
                    <th>Redes</th>
                    <th>Última actualización</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in publicaciones)
                {
                    <tr>
                        <td class="col-primary">@item.Nombre</td>
                        <td class="col-secondary">@item.ResponsableNombre</td>
                        <td class="col-secondary">@item.FechaPublicacionProgramada.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge badge-success">@item.EstadoTexto</span>
                        </td>
                        <td class="col-secondary">@(item.RedesSociales?.Count ?? 0)</td>
                        <td><AuditLastUpdated AuditInfo="item.AuditInfo" /></td>
                        <td>
                            <div class="ui-actions">
                                <a href="/marketing/editar-publicacion/@item.Id" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <Paginacion PaginaActual="paginaActual"
                    TotalPaginas="totalPaginas"
                    OnPaginaChanged="IrAPagina" />
    }
</div>

@code {

    private List<PublicacionMarketingDto> publicaciones = new();

    private bool cargando = true;

    private string? busqueda;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        cargando = true;

        StateHasChanged();

        var resultado =
            await MarketingService.ObtenerTodosConPaginacionAsync(
                busqueda,
                paginaActual,
                tamañoPagina);

        publicaciones = resultado.Items;

        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;

        cargando = false;
    }

    private async Task OnFiltroChanged(
        Dictionary<string, string?> valores)
    {
        busqueda = valores.GetValueOrDefault("busqueda");

        paginaActual = 1;

        await Cargar();
    }

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(
            pagina,
            Cargar);
    }
}
