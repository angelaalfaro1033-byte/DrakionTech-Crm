@page "/marketing/crear-publicacion"
@attribute [Authorize]

@using DrakionTech.Crm.Business.DTOs.Marketing
@using DrakionTech.Crm.Business.DTOs.Usuario
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Data.Entities.Enums
@using Microsoft.AspNetCore.Components.Forms

@inject GoogleDriveService GoogleDriveService
@inject IPublicacionMarketingService PublicacionMarketingService
@inject IUsuarioService UsuarioService
@inject NavigationManager Nav

<div class="page-header">
    <div>
        <h3 class="page-title">Nueva Publicación</h3>
        <p class="page-subtitle">
            Registra una nueva publicación de marketing
        </p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">
        @_error
    </div>
}

<EditForm Model="_modelo" OnValidSubmit="GuardarAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-section">
        <p class="section-title">Información General</p>

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <InputText class="form-control"
                       @bind-Value="_modelo.Nombre" />
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción Campaña</label>
            <InputTextArea class="form-control"
                           rows="3"
                           @bind-Value="_modelo.DescripcionCampania" />
        </div>

        <div class="mb-3">
            <label class="form-label">Copy Utilizado</label>
            <InputTextArea class="form-control"
                           rows="4"
                           @bind-Value="_modelo.CopyUtilizado" />
        </div>

        <div class="mb-3">
            <label class="form-label">
                Archivo
            </label>

            <InputFile OnChange="SeleccionarArchivosAsync"
                       multiple
                       class="form-control" />

            @foreach (var archivo in _archivosSeleccionados)
            {
                <div class="position-relative">
                    @if (!string.IsNullOrWhiteSpace(archivo.PreviewUrl))
                    {
                        <img src="@archivo.PreviewUrl"
                             style="width:150px;height:150px;object-fit:cover"
                             class="img-thumbnail" />
                    }
                    else
                    {
                        <div class="border rounded p-2">@archivo.Nombre</div>
                    }

                    <button type="button"
                            class="btn btn-sm btn-outline-danger mt-1"
                            @onclick="() => EliminarArchivoSeleccionado(archivo)">
                        Eliminar
                    </button>
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Observaciones</label>

            <InputTextArea class="form-control"
                           rows="3"
                           @bind-Value="_modelo.Observaciones" />
        </div>
    </div>

    <div class="form-section">
        <p class="section-title">Responsable y Programación</p>

        <div class="grid-2col">

            <div class="mb-3">
                <label class="form-label">Responsable</label>

                <InputSelect class="form-select"
                             @bind-Value="_modelo.ResponsableId">
                    <option value="0">
                        -- Seleccione --
                    </option>

                    @foreach (var usuario in _usuarios)
                    {
                        <option value="@usuario.Id">
                            @usuario.Nombre @usuario.Apellido
                        </option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Fecha Publicación Programada
                </label>

                <InputDate class="form-control"
                           @bind-Value="_modelo.FechaPublicacionProgramada" />
            </div>

        </div>

        <div class="form-check mt-3">
            <InputCheckbox class="form-check-input"
                           @bind-Value="_modelo.EnvioAutomatico" />

            <label class="form-check-label">
                Envío automático
            </label>
        </div>
    </div>

    <div class="form-section">
        <p class="section-title">Redes Sociales</p>

        @foreach (var red in _modelo.RedesSociales)
        {
            <div class="border rounded p-3 mb-3">

                <div class="grid-2col">

                    <div>
                        <label class="form-label">
                            Red Social
                        </label>

                        <InputSelect class="form-select"
                                     @bind-Value="red.RedSocial">

                            @foreach (var rs in Enum.GetValues<RedSocial>())
                            {
                                <option value="@rs">
                                    @rs
                                </option>
                            }

                        </InputSelect>
                    </div>

                    <div class="d-flex align-items-end">
                        <button type="button"
                                class="btn btn-outline-danger"
                                @onclick="() => EliminarRed(red)">
                            Eliminar
                        </button>
                    </div>

                </div>

                <div class="form-check mt-3">
                    <InputCheckbox class="form-check-input"
                                   @bind-Value="red.TienePauta" />

                    <label class="form-check-label">
                        Tiene pauta
                    </label>
                </div>

                @if (red.TienePauta)
                {
                    <div class="grid-2col mt-3">

                        <div>
                            <label class="form-label">
                                Costo pauta
                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="red.CostoPauta" />
                        </div>

                        <div>
                            <label class="form-label">
                                Días pauta
                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="red.DiasPauta" />
                        </div>

                    </div>
                }

            </div>
        }

        <button type="button"
                class="btn btn-outline-primary"
                @onclick="AgregarRed">
            + Agregar Red Social
        </button>
    </div>

    <div class="form-actions">
        <button type="submit"
                class="btn btn-primary">
            Guardar
        </button>

        <button type="button"
                class="btn btn-secondary"
                @onclick='() => Nav.NavigateTo("/marketing")'>
            Cancelar
        </button>
    </div>

</EditForm>

@code {

    private CrearPublicacionMarketingDto _modelo = new()
    {
        FechaPublicacionProgramada = DateTime.Today
    };

    private List<UsuarioListDto> _usuarios = new();

    private List<string> _previewImagenes = new();
    private const long MaxFileSize = 50 * 1024 * 1024;
    private List<ArchivoSeleccionado> _archivosSeleccionados = new();

    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _usuarios = await UsuarioService.ObtenerTodosAsync(
            soloActivos: true);

        if (!_modelo.RedesSociales.Any())
        {
            AgregarRed();
        }
    }

    private void AgregarRed()
    {
        _modelo.RedesSociales.Add(
            new RedSocialPublicacionDto());
    }

    private void EliminarRed(
        RedSocialPublicacionDto red)
    {
        _modelo.RedesSociales.Remove(red);
    }

    private async Task GuardarAsync()
    {
        _modelo.Archivos.Clear();
        await SubirArchivosPendientesAsync();

        await PublicacionMarketingService.CrearAsync(_modelo);

        try
        {
            await PublicacionMarketingService.CrearAsync(_modelo);

            Nav.NavigateTo("/marketing");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SubirArchivoAsync(InputFileChangeEventArgs e)
    {
        foreach (var archivo in e.GetMultipleFiles())
        {
            if (archivo.ContentType.StartsWith("image/"))
            {
                using var ms = new MemoryStream();

                await archivo
                    .OpenReadStream(10 * 1024 * 1024)
                    .CopyToAsync(ms);

                _previewImagenes.Add(
                    $"data:{archivo.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}");
            }

            await using var stream =
                archivo.OpenReadStream(50 * 1024 * 1024);

            var resultado =
                await GoogleDriveService.SubirArchivoAsync(
                    archivo.Name,
                    archivo.ContentType,
                    stream);

            _modelo.Archivos.Add(new ArchivoPublicacionDto
            {
                Nombre = archivo.Name,
                MimeType = archivo.ContentType,
                ArchivoIdExterno = resultado.fileId,
                Url = resultado.webViewLink
            });
        }
    }

    private async Task SeleccionarArchivosAsync(InputFileChangeEventArgs e)
    {
        foreach (var archivo in e.GetMultipleFiles())
        {
            using var ms = new MemoryStream();
            await archivo.OpenReadStream(MaxFileSize).CopyToAsync(ms);

            var bytes = ms.ToArray();

            _archivosSeleccionados.Add(new ArchivoSeleccionado
            {
                Nombre = archivo.Name,
                MimeType = archivo.ContentType,
                Contenido = bytes,
                PreviewUrl = archivo.ContentType.StartsWith("image/")
                    ? $"data:{archivo.ContentType};base64,{Convert.ToBase64String(bytes)}"
                    : null
            });
        }
    }

    private void EliminarArchivoSeleccionado(ArchivoSeleccionado archivo)
    {
        _archivosSeleccionados.Remove(archivo);
    }

    private async Task SubirArchivosPendientesAsync()
    {
        foreach (var archivo in _archivosSeleccionados)
        {
            await using var stream = new MemoryStream(archivo.Contenido);

            var resultado = await GoogleDriveService.SubirArchivoAsync(
                archivo.Nombre,
                archivo.MimeType,
                stream);

            _modelo.Archivos.Add(new ArchivoPublicacionDto
            {
                Nombre = archivo.Nombre,
                MimeType = archivo.MimeType,
                ArchivoIdExterno = resultado.fileId,
                Url = resultado.webViewLink
            });
        }
    }

    private sealed class ArchivoSeleccionado
    {
        public string Nombre { get; set; } = string.Empty;
        public string MimeType { get; set; } = string.Empty;
        public byte[] Contenido { get; set; } = [];
        public string? PreviewUrl { get; set; }
    }
}