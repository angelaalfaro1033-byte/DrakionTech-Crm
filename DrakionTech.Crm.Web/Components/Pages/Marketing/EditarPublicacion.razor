@page "/marketing/editar-publicacion/{Id:int}"
@attribute [Authorize]
@using DrakionTech.Crm.Web.Components.Marketing

<div class="form-card">
    <div class="form-header">
        <h1>Editar Publicación</h1>
        <p>Actualiza la información de la publicación de marketing</p>
    </div>
    <PublicacionForm PublicacionId="Id" />
</div>

@code {
    [Parameter] public int Id { get; set; }
}