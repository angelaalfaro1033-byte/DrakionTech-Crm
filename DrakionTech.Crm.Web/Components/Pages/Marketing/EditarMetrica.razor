@page "/marketing/editar-metrica/{Id:int}"
@attribute [Authorize]
@using DrakionTech.Crm.Web.Components.Marketing

<div class="form-card">
    <div class="form-header">
        <h1>Editar Métrica</h1>
        <p>Actualiza el seguimiento de una publicación por canal</p>
    </div>
    <MetricaForm MetricaId="Id" />
</div>

@code {
    [Parameter] public int Id { get; set; }
}