@page "/activate"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using DrakionTech.Crm.Business.Interfaces
@inject IEmpleadoService EmpleadoService
@inject NavigationManager Nav

<div class="login-wrapper">
    <div class="login-card">

        <div class="login-header">
            <img src="images/logo/Logo_Negro.svg" alt="DrakionTech CRM" class="login-logo" />
            <p class="activate-subtitulo">Activa tu cuenta y crea tu contraseña</p>
        </div>

        @if (TokenInvalido)
        {
            <div class="login-error">
                <i class="bi bi-x-circle"></i>
                El enlace de activación es inválido o ha expirado. Contacta a tu administrador.
            </div>
            <div class="login-footer">
                <a href="/login">Volver al inicio de sesión</a>
            </div>
        }
        else if (Activado)
        {
            <div class="activate-success">
                <div class="activate-success-icon">
                    <i class="bi bi-check-lg"></i>
                </div>
                <p class="activate-success-title">¡Cuenta activada!</p>
                <p class="activate-success-sub">Redirigiendo al inicio de sesión...</p>
            </div>
        }
        else
        {
            @if (Error is not null)
            {
                <div class="login-error">
                    <i class="bi bi-exclamation-circle"></i>
                    @Error
                </div>
            }

            <div class="login-form">

                <div class="field-group">
                    <label class="field-label">Nueva contraseña</label>
                    <div class="field-input-wrap">
                        <i class="bi bi-lock field-icon"></i>
                        <input type="password"
                               class="field-input"
                               placeholder="Mínimo 8 caracteres"
                               @bind="Password"
                               @bind:event="oninput" />
                    </div>
                    @if (!string.IsNullOrEmpty(Password))
                    {
                        <div class="password-strength">
                            <div class="strength-bar">
                                <div class="strength-fill strength-@FuerzaClase" style="width: @FuerzaPorcentaje%"></div>
                            </div>
                            <span class="strength-label strength-@FuerzaClase">@FuerzaTexto</span>
                        </div>
                        <ul class="password-rules">
                            <li class="@(TieneLongitud  ? "rule-ok" : "rule-pending")">
                                <i class="bi @(TieneLongitud  ? "bi-check-circle-fill" : "bi-circle")"></i>
                                8 caracteres mínimo
                            </li>
                            <li class="@(TieneMayuscula ? "rule-ok" : "rule-pending")">
                                <i class="bi @(TieneMayuscula ? "bi-check-circle-fill" : "bi-circle")"></i>
                                Una letra mayúscula
                            </li>
                            <li class="@(TieneMinuscula ? "rule-ok" : "rule-pending")">
                                <i class="bi @(TieneMinuscula ? "bi-check-circle-fill" : "bi-circle")"></i>
                                Una letra minúscula
                            </li>
                            <li class="@(TieneNumero    ? "rule-ok" : "rule-pending")">
                                <i class="bi @(TieneNumero    ? "bi-check-circle-fill" : "bi-circle")"></i>
                                Un número
                            </li>
                            <li class="@(TieneEspecial ? "rule-ok" : "rule-pending")">
                                <i class="bi @(TieneEspecial ? "bi-check-circle-fill" : "bi-circle")"></i>
                                Un carácter especial (!&#64;&#35;$...)
                            </li>
                        </ul>
                    }
                </div>

                <div class="field-group">
                    <label class="field-label">Confirmar contraseña</label>
                    <div class="field-input-wrap">
                        <i class="bi bi-lock-fill field-icon"></i>
                        <input type="password"
                               class="field-input @ConfirmacionClase"
                               placeholder="Repite tu contraseña"
                               @bind="Confirmar"
                               @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(Confirmar))
                        {
                            <i class="bi @ConfirmacionIcono field-icon-right"></i>
                        }
                    </div>
                </div>

                <button class="login-btn" @onclick="Activar" disabled="@Cargando">
                    @if (Cargando)
                    {
                        <span class="spinner"></span>
                        <span>Activando...</span>
                    }
                    else
                    {
                        <span>Activar cuenta</span>
                        <i class="bi bi-arrow-right"></i>
                    }
                </button>

            </div>
        }

    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private string? Password;
    private string? Confirmar;
    private string? Error;
    private bool Cargando;
    private bool Activado;
    private bool TokenInvalido;

    private bool TieneLongitud  => Password?.Length >= 8;
    private bool TieneMayuscula => Password?.Any(char.IsUpper) ?? false;
    private bool TieneMinuscula => Password?.Any(char.IsLower) ?? false;
    private bool TieneNumero    => Password?.Any(char.IsDigit) ?? false;
    private bool TieneEspecial  => Password?.Any(c => "!@#$%^&*()_+-=[]{}|;':\",./<>?".Contains(c)) ?? false;
    private bool PasswordValida => TieneLongitud && TieneMayuscula && TieneMinuscula && TieneNumero && TieneEspecial;

    private int FuerzaPorcentaje
    {
        get
        {
            if (string.IsNullOrEmpty(Password)) return 0;
            int reglas = new[] { TieneLongitud, TieneMayuscula, TieneMinuscula, TieneNumero, TieneEspecial }
                             .Count(r => r);
            return reglas switch { 1 => 20, 2 => 40, 3 => 60, 4 => 80, 5 => 100, _ => 0 };
        }
    }

    private string FuerzaClase => FuerzaPorcentaje switch
    {
        <= 20 => "debil",
        <= 40 => "media",
        <= 80 => "buena",
        100   => "fuerte",
        _     => "debil"
    };

    private string FuerzaTexto => FuerzaClase switch
    {
        "debil"  => "Débil",
        "media"  => "Regular",
        "buena"  => "Buena",
        "fuerte" => "Fuerte",
        _        => ""
    };

    private bool Coinciden =>
        !string.IsNullOrEmpty(Password) &&
        !string.IsNullOrEmpty(Confirmar) &&
        Password == Confirmar;

    private string ConfirmacionClase =>
        string.IsNullOrEmpty(Confirmar) ? "" : Coinciden ? "input-ok" : "input-error";

    private string ConfirmacionIcono =>
        Coinciden ? "bi-check-circle-fill icon-ok" : "bi-x-circle-fill icon-error";

    private async Task Activar()
    {
        Error = null;

        if (string.IsNullOrWhiteSpace(Token))
        {
            TokenInvalido = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(Password) || string.IsNullOrWhiteSpace(Confirmar))
        {
            Error = "Completa ambos campos.";
            return;
        }

        if (!PasswordValida)
        {
            Error = "La contraseña no cumple con todos los requisitos.";
            return;
        }

        if (!Coinciden)
        {
            Error = "Las contraseñas no coinciden.";
            return;
        }

        Cargando = true;
        var result = await EmpleadoService.ActivarCuentaAsync(Token, Password);
        Cargando = false;

        if (result)
        {
            Activado = true;
            await Task.Delay(2000);
            Nav.NavigateTo("/login?mensaje=cuenta-creada");
        }
        else
        {
            TokenInvalido = true;
        }
    }
}