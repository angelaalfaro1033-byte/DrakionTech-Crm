@page "/empresas/{EmpresaId:int}/oportunidades"
@attribute [Authorize]
@inject IEmpresaService EmpresaService
@inject IOportunidadService OportunidadService

@if (empresa is null || oportunidades is null)
{
    <div class="ui-empty">
        <div class="spinner-border spinner-border-sm mb-2"></div>
        <p>Cargando oportunidades…</p>
    </div>
}
else
{
    <EmpresaComponente Empresa="empresa">
        <div class="detail-section-header">
            <div>
                <h5>Oportunidades</h5>
                <small class="text-muted">Gestión de oportunidades comerciales</small>
            </div>
            <a class="btn btn-primary detail-section-header__action"
               href="/empresas/@EmpresaId/oportunidades/crear">
                <i class="bi bi-plus-lg me-1"></i> Nueva oportunidad
            </a>
        </div>

        @if (!oportunidades.Any())
        {
            <div class="ui-empty">
                <i class="bi bi-briefcase"></i>
                <p>Esta empresa no tiene oportunidades registradas.</p>
            </div>
        }
        else
        {
            <div class="ui-card">
                <table class="ui-table">
                    <thead>
                        <tr>
                            <th>Proyecto</th>
                            <th>Valor estimado</th>
                            <th>Etapa</th>
                            <th>Última actualización</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in _paginaActual)
                        {
                            <tr>
                                <td class="col-primary">@o.NombreProyecto</td>
                                <td class="col-secondary">
                                    @o.ValorEstimado.ToString("C0", new System.Globalization.CultureInfo("es-CO"))
                                </td>
                                <td>
                                    <span class="oport-badge oport-badge--@o.EtapaNombre.ToLower()">
                                        @o.EtapaNombre
                                    </span>
                                </td>
                                <td><AuditLastUpdated AuditInfo="o.AuditInfo" /></td>
                                <td>
                                    <div class="ui-actions">
                                        <a class="oport-btn oport-btn--default"
                                           href="/empresas/@EmpresaId/oportunidades/editar/@o.Id">
                                            <i class="bi bi-pencil"></i> Editar
                                        </a>
                                        <a class="oport-btn oport-btn--primary"
                                           href="/empresas/@EmpresaId/oportunidades/etapa/@o.Id">
                                            <i class="bi bi-arrow-right-circle"></i> Etapa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <Paginacion PaginaActual="_pagina"
                            TotalPaginas="_totalPaginas"
                            OnPaginaChanged="IrAPagina" />
            </div>
        }
    </EmpresaComponente>
}

@code {
    [Parameter] public int EmpresaId { get; set; }

    private EmpresaDto? empresa;
    private IEnumerable<OportunidadDto>? oportunidades;

    private IEnumerable<OportunidadDto> _paginaActual = new List<OportunidadDto>();
    private int _pagina = 1;
    private const int TamañoPagina = 10;
    private int _totalPaginas;

    protected override async Task OnInitializedAsync()
    {
        empresa = await EmpresaService.ObtenerPorIdAsync(EmpresaId);
        oportunidades = await OportunidadService.ObtenerPorEmpresaAsync(EmpresaId);
        ActualizarPagina();
    }

    private void ActualizarPagina()
    {
        var total = oportunidades?.Count() ?? 0;
        _totalPaginas = (int)Math.Ceiling((double)total / TamañoPagina);
        _paginaActual = (oportunidades ?? Enumerable.Empty<OportunidadDto>())
            .Skip((_pagina - 1) * TamañoPagina)
            .Take(TamañoPagina);
    }

    private void IrAPagina(int pagina)
    {
        _pagina = pagina;
        ActualizarPagina();
    }
}
