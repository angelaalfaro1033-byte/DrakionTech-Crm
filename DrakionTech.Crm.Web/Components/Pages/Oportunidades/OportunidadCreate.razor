@page "/empresas/{EmpresaId:int}/oportunidades/crear"
@attribute [Authorize]
@inject IOportunidadService OportunidadService
@inject NavigationManager Navigation

<div class="form-card">

    <div class="form-header">
        <h1>Nueva Oportunidad</h1>
        <p>Completa la información del proyecto comercial</p>
    </div>

        <EditForm Model="@modelo"
                    OnValidSubmit="Guardar"
                    FormName="CrearOportunidadForm">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Nombre del proyecto</label>
                <InputText class="form-control"
                            @bind-Value="modelo.NombreProyecto"/>
            </div>

            <div class="mb-3">
                <label class="form-label">Valor estimado</label>
                <input class="form-control"
                       value="@valorFormateado"
                       @oninput="OnValorInput" />


            </div>

            <div class="mb-3">
                <label class="form-label">Fecha estimada de cierre</label>
                <InputDate class="form-control"
                            @bind-Value="modelo.FechaEstimadaCierre" />
            </div>

            <div class="mb-3">
                <label class="form-label">Descripción</label>
                <InputTextArea class="form-control"
                                @bind-Value="modelo.Descripcion" />
            </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="/empresas/@EmpresaId/oportunidades">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar</button>
        </div>
        </EditForm>
</div>

@code {
    [Parameter] public int EmpresaId { get; set; }

    private CrearOportunidadDto modelo = new();

    protected override void OnInitialized()
    {
        modelo.EmpresaId = EmpresaId;
    }

    private async Task Guardar()
    {
        await OportunidadService.CrearAsync(modelo);
        Navigation.NavigateTo($"/empresas/{EmpresaId}/oportunidades");
    }
    private string valorFormateado = "";

    private void OnValorInput(ChangeEventArgs e)
    {
        var texto = e.Value?.ToString() ?? "";

        var soloNumeros = new string(texto.Where(char.IsDigit).ToArray());

        if (decimal.TryParse(soloNumeros, out var numero))
        {
            modelo.ValorEstimado = numero;
            valorFormateado = numero.ToString("N0");
        }
        else
        {
            valorFormateado = "";
        }
    }

}
