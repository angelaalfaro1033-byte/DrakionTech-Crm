@page "/especialidades"

@using DrakionTech.Crm.Business.DTOs.Especialidad
@using DrakionTech.Crm.Business.Interfaces

@inject IEspecialidadService EspecialidadService

<div class="roles-container">

    <div class="empresas-header">
        <div>
            <h1 class="empresas-title">Especialidades</h1>
            <p class="empresas-subtitle">Gestiona las especialidades del sistema</p>
        </div>
        <a class="btn btn-primary" href="/especialidades/crear">
            + Nueva Especialidad
        </a>
    </div>

    @if (lista is null)
    {
        <p>Cargando especialidades...</p>
    }
    else if (!lista.Any())
    {
        <div class="alert alert-info">No hay especialidades registradas.</div>
    }
    else
    {
        <div class="ui-toolbar">
            <div class="ui-search">
                <i class="bi bi-search"></i>
                <input class="form-control"
                       placeholder="Buscar por nombre..."
                       @bind="busqueda"
                       @bind:event="oninput" />
            </div>
            <select class="form-select" @bind="estadoSeleccionado">
                <option value="">Todos</option>
                <option value="true">Activos</option>
                <option value="false">Inactivos</option>
            </select>
        </div>

        <div class="ui-card">
            <table class="ui-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in listaFiltrada!)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td>@item.Descripcion</td>
                            <td>@item.RolUsuarioNombre</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="ui-actions">
                                    <a href="/especialidades/editar/@item.Id" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (item.Activo)
                                    {
                                        <button class="btn btn-sm btn-success" @onclick="() => Desactivar(item.Id)" title="Desactivar">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary" @onclick="() => Activar(item.Id)" title="Activar">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private List<EspecialidadDto>? lista;
    private IEnumerable<EspecialidadDto>? listaFiltrada;

    private string? _busqueda;
    private string? _estadoSeleccionado;

    private string? busqueda
    {
        get => _busqueda;
        set { _busqueda = value; AplicarFiltros(); }
    }

    private string? estadoSeleccionado
    {
        get => _estadoSeleccionado;
        set { _estadoSeleccionado = value; AplicarFiltros(); }
    }

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        lista = await EspecialidadService.ObtenerTodosAsync();
        AplicarFiltros();
    }

    private void AplicarFiltros()
    {
        if (lista is null) return;
        var query = lista.AsQueryable();

        if (!string.IsNullOrWhiteSpace(busqueda))
            query = query.Where(e => e.Nombre.ToLower().Contains(busqueda.Trim().ToLower()));

        if (!string.IsNullOrWhiteSpace(estadoSeleccionado))
            query = query.Where(e => e.Activo == bool.Parse(estadoSeleccionado));

        listaFiltrada = query.ToList();
    }

    private async Task Desactivar(int id) { await EspecialidadService.DesactivarAsync(id); await Cargar(); }
    private async Task Activar(int id) { await EspecialidadService.ActivarAsync(id); await Cargar(); }
}