@page "/especialidades"

@using DrakionTech.Crm.Business.DTOs.Especialidad
@using DrakionTech.Crm.Business.Interfaces
@using DrakionTech.Crm.Web.Components
@using DrakionTech.Crm.Web.Shared
@inherits PaginacionBase

@inject IEspecialidadService EspecialidadService

<div class="especialidades-container">

    <div class="page-header">
        <div>
            <h1 class="page-title">Especialidades</h1>
            <p class="page-subtitle">Gestiona las especialidades del sistema</p>
        </div>
        <a class="btn btn-primary" href="/especialidades/crear">
            + Nueva Especialidad
        </a>
    </div>

    <FiltroTabla TItem="EspecialidadDto"
                 PlaceholderBusqueda="Buscar por nombre..."
                 MostrarFiltroEstado="true"
                 OnFiltroChanged="OnFiltroChanged" />

    @if (cargando)
    {
        <p>Cargando especialidades...</p>
    }
    else if (!lista.Any())
    {
        <div class="alert alert-info">No hay especialidades registradas.</div>
    }
    else
    {
        <div class="ui-card">
            <table class="ui-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in lista)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td>@item.Descripcion</td>
                            <td>@item.RolUsuarioNombre</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="ui-actions">
                                    <a href="/especialidades/editar/@item.Id" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (item.Activo)
                                    {
                                        <button class="btn btn-sm btn-success"
                                                @onclick="() => Desactivar(item.Id)"
                                                title="Desactivar">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="() => Activar(item.Id)"
                                                title="Activar">
                                            <i class="bi bi-toggle-off"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Paginacion PaginaActual="paginaActual"
                        TotalPaginas="totalPaginas"
                        OnPaginaChanged="IrAPagina" />
        </div>
    }

</div>

@code {
    private List<EspecialidadDto> lista = new();
    private bool cargando = true;
    private string? busqueda;
    private bool? soloActivos;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        cargando = true;
        StateHasChanged();
        var resultado = await EspecialidadService.ObtenerTodosConPaginacionAsync(
            busqueda,
            soloActivos,
            paginaActual,
            tamañoPagina);

        lista = resultado.Items;

        totalRegistros = resultado.TotalRegistros;
        totalPaginas = resultado.TotalPaginas;
        cargando = false;
    }

    private async Task OnFiltroChanged(Dictionary<string, string?> valores)
    {
        busqueda = valores.GetValueOrDefault("busqueda");
        var estado = valores.GetValueOrDefault("estado");
        soloActivos = string.IsNullOrWhiteSpace(estado) ? null : bool.Parse(estado);
        paginaActual = 1;
        await Cargar();
    }

    private async Task Desactivar(int id) => await CambiarEstado(id, EspecialidadService.DesactivarAsync);
    private async Task Activar(int id)    => await CambiarEstado(id, EspecialidadService.ActivarAsync);

    private async Task CambiarEstado(int id, Func<int, Task> accion)
    {
        await accion(id);
        await Cargar();
    }

    private async Task IrAPagina(int pagina)
    {
        await CambiarPaginaAsync(pagina, Cargar);
    }
}