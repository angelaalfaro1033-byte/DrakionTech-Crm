@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <img src="images/logo/Logo_Negro.svg" alt="DrakionTech CRM" class="login-logo" />
        </div>

        @if (Mensaje is not null)
        {
            <div class="login-success">
                <i class="bi bi-check-circle"></i>
                @Mensaje
            </div>
        }

        @if (Error is not null)
        {
            <div class="login-error">
                <i class="bi bi-exclamation-circle"></i>
                @Error
            </div>
        }

        <form method="post" action="/account/login" class="login-form">
            <div class="field-group">
                <label class="field-label">Correo electrónico</label>
                <div class="field-input-wrap">
                    <i class="bi bi-envelope field-icon"></i>
                    <input name="email" type="email" class="field-input" placeholder="tucorreo@empresa.com" />
                </div>
            </div>

            <div class="field-group">
                <label class="field-label">Contraseña</label>
                <div class="field-input-wrap">
                    <i class="bi bi-lock field-icon"></i>
                    <input name="password" type="password" class="field-input" placeholder="••••••••" />
                </div>
            </div>

            <button type="submit" class="login-btn">
                Ingresar
                <i class="bi bi-arrow-right"></i>
            </button>

            <div class="login-divider">
                <span>o continúa con</span>
            </div>

            <a href="/account/google-login" class="google-btn">
                <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05" />
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                </svg>
                Continuar con Google
            </a>

            <div class="login-footer">
                <span>¿Primera vez aquí?</span>
                <a href="/registro-inicial">Crea tu cuenta</a>
            </div>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? error { get; set; }
    [SupplyParameterFromQuery] private string? mensaje { get; set; }

    private string? Error => error switch
    {
        "credenciales" => "Correo o contraseña incorrectos.",
        "inactivo" => "Tu cuenta no está activada.",
        "google" => "No se pudo iniciar sesión con Google. Intenta de nuevo.",
        "no-registrado" => "Tu cuenta de Google no está registrada en el sistema.",
        _ => null
    };

    private string? Mensaje => mensaje switch
    {
        "cuenta-creada" => "¡Cuenta creada! Ya puedes iniciar sesión.",
        _ => null
    };
}