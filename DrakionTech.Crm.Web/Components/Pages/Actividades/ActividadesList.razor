@page "/empresas/{EmpresaId:int}/actividades"
@using DrakionTech.Crm.Data.Entities.Enums
@inject IEmpresaService EmpresaService
@inject IActividadService ActividadService
@inject NavigationManager Nav
@attribute [Authorize]

@if (empresa is null || actividades is null)
{
    <div class="ui-empty">
        <div class="spinner-border spinner-border-sm mb-2"></div>
        <p>Cargando actividades…</p>
    </div>
}
else
{
    <EmpresaComponente Empresa="empresa">
        <div class="empresa-actividades">
            <div class="detail-section-header">
                <div>
                    <h5>Actividades</h5>
                    <small class="text-muted">Historial de interacciones</small>
                </div>
                <a class="btn btn-primary detail-section-header__action"
                   href="/empresas/@EmpresaId/actividades/crear">
                    <i class="bi bi-plus-lg me-1"></i> Nueva actividad
                </a>
            </div>

            @if (!actividades.Any())
            {
                <div class="ui-empty">
                    <i class="bi bi-calendar-x"></i>
                    <p>No hay actividades registradas.</p>
                </div>
            }
            else
            {
                <div class="ui-toolbar detail-toolbar mt-3 mb-3">
                    <div class="flex-fill">
                        <input type="date" class="form-control" @bind="fechaSeleccionada" />
                    </div>
                    <div class="flex-fill">
                        <select class="form-control" @bind="tipoSeleccionado">
                            <option value="">-- Todos los tipos --</option>
                            @foreach (var tipo in tipos)
                            {
                                <option value="@tipo">@tipo</option>
                            }
                        </select>
                    </div>
                    <div class="flex-fill">
                        <select class="form-control" @bind="oportunidadSeleccionada">
                            <option value="">-- Todas las oportunidades --</option>
                            @foreach (var op in oportunidades)
                            {
                                <option value="@op">@op</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="ui-card">
                    <table class="ui-table">
                        <thead>
                            <tr>
                                <th>Estado</th>
                                <th>Tipo</th>
                                <th>Fecha</th>
                                <th>Resultado</th>
                                <th>Última actualización</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _paginaActual)
                            {
                                <tr>
                                    <td>
                                        <span class="badge badge-estado badge-@a.ClasificacionEstado?.ToLower()">
                                            @a.ClasificacionEstado
                                        </span>
                                    </td>
                                    <td class="col-primary">@a.TipoActividadNombre</td>
                                    <td class="col-secondary">@a.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td class="col-secondary">@(string.IsNullOrEmpty(a.Resultado) ? "—" : a.Resultado)</td>
                                    <td><AuditLastUpdated AuditInfo="a.AuditInfo" /></td>
                                    <td>
                                        <div class="ui-actions">
                                            @if (a.ClasificacionEstado == "Programada")
                                            {
                                                <button type="button" class="btn-completar"
                                                        title="Marcar como completada"
                                                        @onclick="() => CompletarAsync(a.Id)"
                                                        disabled="@_completando.Contains(a.Id)">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                            <a href="/empresas/@EmpresaId/actividades/editar/@a.Id" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <Paginacion PaginaActual="_pagina"
                                TotalPaginas="_totalPaginas"
                                OnPaginaChanged="IrAPagina" />
                </div>
            }
        </div>
    </EmpresaComponente>
}

@code {
    [Parameter] public int EmpresaId { get; set; }

    private EmpresaDto? empresa;

    private HashSet<int> _completando = [];

    private IEnumerable<ActividadDto>? actividades;
    private IEnumerable<ActividadDto>? actividadesFiltradas;
    private List<string> tipos = new();
    private List<string> oportunidades = new();

    private int _pagina = 1;
    private const int TamañoPagina = 10;
    private int _totalPaginas;
    private IEnumerable<ActividadDto> _paginaActual = new List<ActividadDto>();

    private DateTime? _fechaSeleccionada;
    private string? _tipoSeleccionado;
    private string? _oportunidadSeleccionada;

    private DateTime? fechaSeleccionada
    {
        get => _fechaSeleccionada;
        set
        {
            _fechaSeleccionada = value;
            AplicarFiltros();
        }
    }

    private string? tipoSeleccionado
    {
        get => _tipoSeleccionado;
        set
        {
            _tipoSeleccionado = value;
            AplicarFiltros();
        }
    }

    private string? oportunidadSeleccionada
    {
        get => _oportunidadSeleccionada;
        set
        {
            _oportunidadSeleccionada = value;
            AplicarFiltros();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        empresa = await EmpresaService.ObtenerPorIdAsync(EmpresaId);
        actividades = await ActividadService.ObtenerPorEmpresaAsync(EmpresaId);

        actividadesFiltradas = actividades;

        tipos = actividades
            .Where(a => !string.IsNullOrWhiteSpace(a.TipoActividadNombre))
            .Select(a => a.TipoActividadNombre!)
            .Distinct()
            .OrderBy(t => t)
            .ToList();

        oportunidades = actividades
            .Where(a => !string.IsNullOrWhiteSpace(a.OportunidadNombre))
            .Select(a => a.OportunidadNombre!)
            .Distinct()
            .OrderBy(o => o)
            .ToList();

        ActualizarPagina();
    }

    private void AplicarFiltros()
    {
        if (actividades is null) return;

        var query = actividades.AsQueryable();

        if (fechaSeleccionada.HasValue)
        {
            query = query.Where(a =>
                a.Fecha.Date == fechaSeleccionada.Value.Date);
        }

        if (!string.IsNullOrWhiteSpace(tipoSeleccionado))
        {
            query = query.Where(a =>
                a.TipoActividadNombre == tipoSeleccionado);
        }

        if (!string.IsNullOrWhiteSpace(oportunidadSeleccionada))
        {
            query = query.Where(a =>
                a.OportunidadNombre == oportunidadSeleccionada);
        }

        actividadesFiltradas = query.ToList();
        _pagina = 1;
        ActualizarPagina();
    }

    private void ActualizarPagina()
    {
        var total = actividadesFiltradas?.Count() ?? 0;
        _totalPaginas = (int)Math.Ceiling((double)total / TamañoPagina);
        _paginaActual = (actividadesFiltradas ?? Enumerable.Empty<ActividadDto>())
            .Skip((_pagina - 1) * TamañoPagina)
            .Take(TamañoPagina);
    }

    private void IrAPagina(int pagina)
    {
        _pagina = pagina;
        ActualizarPagina();
    }

    private async Task CompletarAsync(int id)
    {
        _completando.Add(id);
        await ActividadService.CompletarAsync(id);
        _completando.Remove(id);

        actividades = await ActividadService.ObtenerPorEmpresaAsync(EmpresaId);
        AplicarFiltros();
    }
}
