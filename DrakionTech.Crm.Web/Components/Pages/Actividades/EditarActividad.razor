@page "/empresas/{EmpresaId:int}/actividades/editar/{Id:int}"
@attribute [Authorize]
@inject IActividadService ActividadService
@inject IContactoService ContactoService
@inject IOportunidadService OportunidadService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@using DrakionTech.Crm.Web.Extensions
@using Microsoft.AspNetCore.Components.Authorization

<div class="form-card">

    <div class="form-header">
        <h1>Editar actividad</h1>
        <p>Registra una interacción realizada con la empresa</p>
    </div>

        @if (modelo is null)
        {
            <p>Cargando...</p>
        }
        else
        {
            <EditForm Model="@modelo"
                      OnValidSubmit="Guardar"
                      FormName="EditarActividadForm">

                <DataAnnotationsValidator />
                <ValidationSummary />

                <!-- Tipo -->
                <div class="mb-3">
                    <label class="form-label">Tipo de actividad</label>
                    <InputSelect class="form-control" @bind-Value="modelo.TipoActividadId">

                        <option value="">-- Seleccione --</option>

                        @foreach (var tipo in tiposActividad)
                        {
                            <option value="@tipo.Id">@tipo.Nombre</option>
                        }

                    </InputSelect>
                </div>

                <!-- Fecha -->
                <div class="mb-3">
                    <label class="form-label">Fecha</label>
                    <InputDate class="form-control"
                               @bind-Value="modelo.Fecha" />
                </div>

                <!-- Resultado -->
                <div class="mb-3">
                    <label class="form-label">Resultado</label>
                    <InputText class="form-control"
                               @bind-Value="modelo.Resultado" />
                </div>

                <!-- Contacto -->
                <div class="mb-3">
                    <label class="form-label">Contacto</label>
                    <InputSelect class="form-control"
                                 @bind-Value="modelo.ContactoId">
                        <option value="">-- Sin contacto --</option>
                        @foreach (var c in contactos)
                        {
                            <option value="@c.Id">@c.NombreCompleto</option>
                        }
                    </InputSelect>
                </div>

                <!-- Oportunidad -->
                <div class="mb-3">
                    <label class="form-label">Oportunidad</label>
                    <InputSelect class="form-control"
                                 @bind-Value="modelo.OportunidadId">
                        <option value="">-- Sin oportunidad --</option>
                        @foreach (var o in oportunidades)
                        {
                            <option value="@o.Id">@o.NombreProyecto</option>
                        }
                    </InputSelect>
                </div>

                <!-- Notas -->
                <div class="mb-3">
                    <label class="form-label">Notas</label>
                    <InputTextArea class="form-control"
                                   rows="4"
                                   @bind-Value="modelo.Notas" />
                </div>

            <div class="form-actions">
                <a class="btn btn-secondary" href="/empresas/@EmpresaId/actividades">Cancelar</a>
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
            </div>
            </EditForm>
        }
</div>

@code {
    [Parameter] public int EmpresaId { get; set; }
    [Parameter] public int Id { get; set; }
    private IEnumerable<TipoActividadDto> tiposActividad = [];

    private ActualizarActividadDto? modelo;
    private IEnumerable<ContactoDto> contactos = [];
    private IEnumerable<OportunidadDto> oportunidades = [];
    private int usuarioId;
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var usuarioId = authState.User.GetUsuarioId();

        var actividad = await ActividadService.ObtenerPorIdAsync(Id);

        modelo = new ActualizarActividadDto
            {
                TipoActividadId = actividad.TipoActividadId,
                Fecha = actividad.Fecha,
                Resultado = actividad.Resultado ?? string.Empty,
                Notas = actividad.Notas,
                ContactoId = actividad.ContactoId,
                OportunidadId = actividad.OportunidadId,
                UsuarioId = usuarioId,
                EstadoActividadId = actividad.EstadoActividadId
            };

        contactos = await ContactoService.ObtenerPorEmpresaAsync(EmpresaId);
        oportunidades = await OportunidadService.ObtenerPorEmpresaAsync(EmpresaId);
        tiposActividad = await ActividadService.ObtenerTiposActividadAsync();
    }
    private async Task Guardar()
    {
        await ActividadService.ActualizarAsync(Id, modelo!);
        Navigation.NavigateTo($"/empresas/{EmpresaId}/actividades");
    }
}