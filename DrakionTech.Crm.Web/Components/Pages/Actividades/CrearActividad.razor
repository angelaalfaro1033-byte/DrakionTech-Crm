@page "/empresas/{EmpresaId:int}/actividades/crear"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IActividadService ActividadService
@inject IContactoService ContactoService
@inject IOportunidadService OportunidadService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@using DrakionTech.Crm.Web.Extensions
@using Microsoft.AspNetCore.Components.Authorization

<div class="form-card">

    <div class="form-header">
        <h1>@(modelo.ActividadPreviaId.HasValue ? "Nueva actividad de seguimiento" : "Nueva actividad")</h1>
        <p>Registra una interacción realizada con la empresa</p>
    </div>

    @if (modelo.ActividadPreviaId.HasValue)
    {
        <div class="seguimiento-banner">
            <i class="bi bi-arrow-return-right"></i>
            Actividad de seguimiento — vinculada a actividad #@modelo.ActividadPreviaId
        </div>
    }

        <EditForm Model="@modelo"
                  OnValidSubmit="Guardar"
                  FormName="CrearActividadForm">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <!-- Tipo -->
            <div class="mb-3">
                <label class="form-label">Tipo de actividad</label>
                <InputSelect class="form-control" @bind-Value="modelo.TipoActividadId">
                    <option value="">-- Seleccione --</option>
                    @foreach (var tipo in tiposActividad)
                    {
                        <option value="@tipo.Id">@tipo.Nombre</option>
                    }
                </InputSelect>
            </div>

            <!-- Fecha -->
            <div class="mb-3">
                <label class="form-label">Fecha</label>
                <InputDate TValue="DateTime"
                           class="form-control"
                           @bind-Value="modelo.Fecha" />
            </div>

            <!-- Fecha de vencimiento -->
            <div class="mb-3">
                <label class="form-label">Fecha de vencimiento</label>
                <InputDate TValue="DateTime?"
                           class="form-control"
                           @bind-Value="modelo.FechaFin" />
                <div class="form-text">Fecha límite para completar la actividad</div>
            </div>

            <!-- Resultado -->
            <div class="mb-3">
                <label class="form-label">Resultado</label>
                <InputText class="form-control" @bind-Value="modelo.Resultado" />
                <div class="form-text">Ejemplo: Reunión realizada, Cliente interesado, No contestó</div>
            </div>

            <!-- Contacto -->
            <div class="mb-3">
                <label class="form-label">Contacto (opcional)</label>
                <InputSelect class="form-control" @bind-Value="modelo.ContactoId">
                    <option value="">-- Sin contacto --</option>
                    @foreach (var c in contactos)
                    {
                        <option value="@c.Id">@c.NombreCompleto</option>
                    }
                </InputSelect>
            </div>

            <!-- Oportunidad -->
            <div class="mb-3">
                <label class="form-label">Oportunidad (opcional)</label>
                <InputSelect class="form-control" @bind-Value="modelo.OportunidadId">
                    <option value="">-- Sin oportunidad --</option>
                    @foreach (var o in oportunidades)
                    {
                        <option value="@o.Id">@o.NombreProyecto</option>
                    }
                </InputSelect>
            </div>

            <!-- Notas -->
            <div class="mb-3">
                <label class="form-label">Notas</label>
                <InputTextArea class="form-control" rows="4" @bind-Value="modelo.Notas" />
            </div>

        <div class="form-actions">
            <a class="btn btn-secondary" href="/dashboardActividades">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar</button>
        </div>

        </EditForm>
</div>

@code {
    [Parameter] public int EmpresaId { get; set; }

    [SupplyParameterFromQuery(Name = "previaId")]
    public int? PreviaId { get; set; }

    private IEnumerable<TipoActividadDto> tiposActividad = [];
    private CrearActividadDto modelo = new();
    private IEnumerable<ContactoDto> contactos = [];
    private IEnumerable<OportunidadDto> oportunidades = [];
    private int usuarioId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        usuarioId = authState.User.GetUsuarioId();

        modelo.EmpresaId = EmpresaId;
        modelo.Fecha = DateTime.Today;
        modelo.EstadoActividadId = 1;
        modelo.UsuarioId = usuarioId;

        if (PreviaId.HasValue)
            modelo.ActividadPreviaId = PreviaId.Value;

        contactos = await ContactoService.ObtenerPorEmpresaAsync(EmpresaId);
        oportunidades = await OportunidadService.ObtenerPorEmpresaAsync(EmpresaId);
        tiposActividad = await ActividadService.ObtenerTiposActividadAsync();
    }

    private async Task Guardar()
    {
        try
        {
            var id = await ActividadService.CrearAsync(modelo);
            Navigation.NavigateTo($"/empresas/{EmpresaId}/actividades");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar: {ex.Message}");
            Console.WriteLine($"Inner: {ex.InnerException?.Message}");
        }
    }
}