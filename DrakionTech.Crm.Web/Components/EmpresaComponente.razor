@if (Empresa is null)
{
    <p>Cargando empresa...</p>
}
else
{
    <div class="empresa-header">
        <h3 class="empresa-nombre">@Empresa.Nombre</h3>
        <small class="empresa-meta">
            @Empresa.NumeroDocumento · @Empresa.PaisNombre
        </small>
    </div>
    <EmpresaDetalleTabs EmpresaId="@Empresa.Id" />
    <div class="empresa-content">
        @ChildContent
    </div>
}

@code {
    [Parameter, EditorRequired]
    public EmpresaDto Empresa { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
