@using DrakionTech.Crm.Business.DTOs.Area
@using DrakionTech.Crm.Business.DTOs.Usuario
@inject IAreaService AreaService
@inject IUsuarioService UsuarioService
@inject NavigationManager Nav
@implements IDisposable

<EditForm Model="modelo" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    @if (!string.IsNullOrEmpty(errorServidor))
    {
        <div class="alert alert-danger py-2 mb-3" style="font-size:13px">
            <i class="bi bi-x-circle me-1"></i> @errorServidor
        </div>
    }

    <div class="mb-3">
        <label class="form-label">
            Nombre del área <span class="text-danger">*</span>
        </label>
        <InputText class="@inputNombreClass"
                   @bind-Value="modelo.Nombre"
                   @oninput="OnNombreInput"
                   placeholder="Ej: Tecnología e Innovación" />
        @if (nombreDuplicado)
        {
            <div class="invalid-feedback d-block" style="font-size:12px">
                <i class="bi bi-exclamation-circle me-1"></i>
                Ya existe un área con este nombre (sin distinción de mayúsculas/minúsculas).
            </div>
        }
        <ValidationMessage For="@(() => modelo.Nombre)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Descripción</label>
        <InputTextArea class="form-control" rows="3"
                       @bind-Value="modelo.Descripcion"
                       placeholder="Breve descripción del área y sus funciones…"
                       style="resize:none;height:auto" />
        <div class="text-muted mt-1" style="font-size:12px">
            @(modelo.Descripcion?.Length ?? 0) / 300 caracteres
        </div>
        <ValidationMessage For="@(() => modelo.Descripcion)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Responsable del área</label>
        <select class="form-select" @bind="responsableSeleccionado" @bind:after="OnResponsableCambiado">
            <option value="0">— Sin responsable —</option>
            @foreach (var u in usuariosDelArea)
            {
                <option value="@u.Id">@u.Nombre @u.Apellido</option>
            }
        </select>
        @if (errorResponsable is not null)
        {
            <div class="text-danger mt-1" style="font-size:12px">
                <i class="bi bi-exclamation-circle me-1"></i> @errorResponsable
            </div>
        }
        @if (!AreaId.HasValue || AreaId == 0)
        {
            <div class="text-muted mt-1" style="font-size:12px">
                <i class="bi bi-info-circle me-1"></i>
                El responsable seleccionado quedará asignado al crear el área
            </div>
        }
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary d-flex align-items-center gap-2"
                disabled="@(guardando || nombreDuplicado || errorResponsable is not null)">
            @if (guardando)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            else
            {
                <i class="bi bi-check-lg"></i>
            }
            @(AreaId.HasValue ? "Guardar cambios" : "Crear área")
        </button>
        <a href="/areas" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</EditForm>

@code {
    [Parameter] public int? AreaId { get; set; }
    [Parameter] public EventCallback<AreaDto> OnGuardado { get; set; }

    private CrearAreaDto modelo = new() { Activa = true };
    private int responsableSeleccionado = 0;
    private bool guardando;
    private string? errorServidor;
    private string? errorResponsable;
    private bool nombreDuplicado;
    private List<UsuarioListDto> usuariosDelArea = new();
    private System.Timers.Timer? debounceNombre;


    private async Task CargarAreaParaEdicion()
    {
        var area = await AreaService.ObtenerPorIdAsync(AreaId!.Value);
        if (area is null) return;

        modelo = new CrearAreaDto
            {
                Nombre = area.Nombre,
                Descripcion = area.Descripcion,
                Activa = area.Activa,
                ResponsableId = area.ResponsableId
            };
        responsableSeleccionado = area.ResponsableId ?? 0;
    }

    private string inputNombreClass => nombreDuplicado ? "form-control is-invalid" : "form-control";

    protected override async Task OnParametersSetAsync()
    {
        await CargarUsuariosDelAreaAsync();

        if (AreaId.HasValue && AreaId > 0)
            await CargarAreaParaEdicion();
    }

    private async Task CargarUsuariosDelAreaAsync()
    {
        var todos = await UsuarioService.ObtenerTodosAsync();
        usuariosDelArea = todos.Where(u => u.IsActive).ToList();
    }

    private void OnNombreInput(ChangeEventArgs e)
    {
        modelo.Nombre = e.Value?.ToString() ?? string.Empty;
        debounceNombre?.Stop();
        debounceNombre?.Dispose();
        debounceNombre = new System.Timers.Timer(500) { AutoReset = false };
        debounceNombre.Elapsed += async (_, _) =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    nombreDuplicado = !string.IsNullOrWhiteSpace(modelo.Nombre) &&
                        await AreaService.NombreExisteAsync(modelo.Nombre, AreaId);
                    StateHasChanged();
                });
            }
            catch (ObjectDisposedException) { }
        };
        debounceNombre.Start();
    }

    private void OnResponsableCambiado()
    {
        errorResponsable = null;
        modelo.ResponsableId = responsableSeleccionado == 0 ? null : responsableSeleccionado;
    }

    private async Task HandleSubmit()
    {
        if (nombreDuplicado || errorResponsable is not null) return;

        guardando = true;
        errorServidor = null;

        try
        {
            AreaDto resultado;

            if (AreaId.HasValue && AreaId > 0)
            {
                resultado = await AreaService.ActualizarAsync(AreaId.Value, new ActualizarAreaDto
                    {
                        Nombre = modelo.Nombre,
                        Descripcion = modelo.Descripcion,
                        Activa = modelo.Activa,
                        ResponsableId = modelo.ResponsableId
                    });
            }
            else
            {
                resultado = await AreaService.CrearAsync(modelo);
            }

            if (OnGuardado.HasDelegate)
                await OnGuardado.InvokeAsync(resultado);
            else
                Nav.NavigateTo("/areas");
        }
        catch (InvalidOperationException ex)
        {
            errorServidor = ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }
    public void Dispose()
    {
        debounceNombre?.Stop();
        debounceNombre?.Dispose();
        debounceNombre = null;
    }
}